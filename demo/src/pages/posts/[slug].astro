---
import { type CollectionEntry, getCollection } from "astro:content";
import PostDetails from "@astro-minimax/core/layouts/PostDetails.astro";
import getSortedPosts from "@astro-minimax/core/utils/getSortedPosts";
import MarkmapInit from "@astro-minimax/viz/components/MarkmapInit.astro";
import MermaidInit from "@astro-minimax/viz/components/MermaidInit.astro";
import { SITE } from "@/config";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.[^.]+$/, "") },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<"blog"> };
const { post } = Astro.props;
const lang = SITE.lang || "en";

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);

const postBody = post.body ?? "";
const hasMarkmap = postBody.includes("```markmap");
const hasMermaid = postBody.includes("```mermaid");
---

<PostDetails {post} posts={sortedPosts} {lang}>
  <Fragment slot="post-scripts">
    {hasMarkmap && <MarkmapInit />}
    {hasMermaid && <MermaidInit />}
  </Fragment>
</PostDetails>
