---
import Layout from "@astro-minimax/core/layouts/Layout.astro";
import Header from "@astro-minimax/core/components/nav/Header.astro";
import Footer from "@astro-minimax/core/components/nav/Footer.astro";
import Card from "@astro-minimax/core/components/ui/Card.astro";
import { getCollection } from "astro:content";
import getSortedPosts from "@astro-minimax/core/utils/getSortedPosts";
import { SITE } from "@/config";
import { t } from "@astro-minimax/core/utils/i18n";

const lang = SITE.lang || "en";
const posts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = getSortedPosts(posts).slice(0, SITE.postPerIndex ?? 4);
---

<Layout title={SITE.title} lang={lang}>
  <Header {lang} />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <section class="pt-8 pb-6">
      <h1 class="text-2xl font-bold">{SITE.title}</h1>
      <p class="mt-2 text-gray-600 dark:text-gray-400">{SITE.desc}</p>
      <p class="mt-4 text-sm text-gray-500 dark:text-gray-500">
        Powered by <strong>@astro-minimax/core</strong> + <strong>@astro-minimax/viz</strong>
      </p>
    </section>

    <section>
      <h2 class="mb-4 text-lg font-semibold">{t("post.recentPosts", lang)}</h2>
      <ul class="space-y-4">
        {sortedPosts.map(post => <Card lang={lang} {...post} />)}
      </ul>
    </section>
  </main>
  <Footer {lang} />
</Layout>
