{
  "name": "@astro-minimax/notify",
  "version": "0.8.0",
  "type": "module",
  "description": "Multi-channel notification package for astro-minimax blogs — supports Telegram, Email (Resend), and more.",
  "author": "Souloss",
  "license": "MIT",
  "keywords": [
    "astro",
    "notification",
    "telegram",
    "email",
    "resend",
    "webhook"
  ],
  "homepage": "https://github.com/souloss/astro-minimax#readme",
  "bugs": {
    "url": "https://github.com/souloss/astro-minimax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/souloss/astro-minimax",
    "directory": "packages/notify"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  },
  "dependencies": {
    "grammy": "^1.41.1"
  },
  "optionalDependencies": {
    "undici": "^6.0.0"
  },
  "peerDependencies": {
    "resend": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "resend": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260313.1",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
