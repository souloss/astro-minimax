{
  "name": "@astro-minimax/viz",
  "version": "0.7.0",
  "type": "module",
  "description": "Visualization plugin package for astro-minimax — Mermaid, Markmap, Rough.js, Excalidraw, Asciinema and more.",
  "author": "Souloss",
  "license": "MIT",
  "keywords": [
    "astro",
    "visualization",
    "mermaid",
    "markmap",
    "excalidraw",
    "asciinema",
    "diagrams",
    "charts"
  ],
  "homepage": "https://github.com/souloss/astro-minimax#readme",
  "bugs": {
    "url": "https://github.com/souloss/astro-minimax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/souloss/astro-minimax",
    "directory": "packages/viz"
  },
  "exports": {
    ".": "./src/integration.ts",
    "./integration": "./src/integration.ts",
    "./components/*.astro": "./src/components/*.astro",
    "./plugins/remark-mermaid-codeblock": "./src/plugins/remark-mermaid-codeblock.ts",
    "./plugins/remark-markmap-codeblock": "./src/plugins/remark-markmap-codeblock.ts",
    "./plugins": "./src/plugins/index.ts",
    "./styles/source.css": "./src/styles/source.css",
    "./scripts/*": "./src/scripts/*.ts",
    "./package.json": "./package.json"
  },
  "files": [
    "src/"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules/.cache"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0",
    "mermaid": "^11.0.0"
  },
  "dependencies": {
    "markmap-lib": "^0.18.11",
    "markmap-view": "^0.18.10",
    "remark-markmap": "^1.1.5",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
