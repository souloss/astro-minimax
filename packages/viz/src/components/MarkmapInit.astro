---
/**
 * Markmap initialization script for client-side rendering.
 * Loads CDN scripts and handles rendering on View Transitions navigation.
 */
---

<script>
  const CDN_SCRIPTS = [
    { src: 'https://cdn.jsdelivr.net/npm/d3@7', global: 'd3' },
    { src: 'https://cdn.jsdelivr.net/npm/markmap-view', global: 'markmap' },
    { src: 'https://cdn.jsdelivr.net/npm/markmap-toolbar', global: 'markmap' },
  ];

  const STYLE_HREF = 'https://cdn.jsdelivr.net/npm/markmap-toolbar/dist/style.css';

  function debounce<T extends unknown[]>(fn: (...args: T) => void, delay: number) {
    let timer: ReturnType<typeof setTimeout>;
    return function(this: unknown, ...args: T) {
      clearTimeout(timer);
      timer = setTimeout(() => fn.apply(this, args), delay);
    };
  }

  function updateMarkmapTheme(isDark: boolean) {
    if (isDark) {
      document.documentElement.classList.add('markmap-dark');
    } else {
      document.documentElement.classList.remove('markmap-dark');
    }
  }

  function loadScript(src: string): Promise<void> {
    return new Promise((resolve, reject) => {
      const existing = document.querySelector(`script[src="${src}"]`) as HTMLScriptElement;
      if (existing) {
        if (existing.dataset.loaded === 'true') {
          resolve();
        } else {
          existing.addEventListener('load', () => resolve());
          existing.addEventListener('error', () => reject(new Error(`Failed to load ${src}`)));
        }
        return;
      }
      const script = document.createElement('script');
      script.src = src;
      script.dataset.loaded = 'false';
      script.onload = () => {
        script.dataset.loaded = 'true';
        resolve();
      };
      script.onerror = () => reject(new Error(`Failed to load ${src}`));
      document.head.appendChild(script);
    });
  }

  function loadStyle(href: string): void {
    if (document.querySelector(`link[href="${href}"]`)) return;
    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = href;
    document.head.appendChild(link);
  }

  let scriptsLoading = false;
  let scriptsLoaded = false;

  async function loadMarkmapScripts(): Promise<boolean> {
    if (scriptsLoaded) return true;
    if (scriptsLoading) {
      return new Promise((resolve) => {
        const check = () => {
          if (scriptsLoaded) resolve(true);
          else setTimeout(check, 50);
        };
        check();
      });
    }

    scriptsLoading = true;
    try {
      await Promise.all(CDN_SCRIPTS.map(s => loadScript(s.src)));
      loadStyle(STYLE_HREF);
      scriptsLoaded = true;
      return true;
    } catch (error) {
      // eslint-disable-next-line no-console
      console.error('Failed to load markmap scripts:', error);
      return false;
    }
  }

  function isMarkmapLoaded(): boolean {
    return typeof (window as { markmap?: unknown }).markmap !== 'undefined';
  }

  async function renderMarkmapContainer(container: HTMLElement) {
    if (container.dataset.rendered === 'true') return;
    
    const rootScript = container.querySelector<HTMLScriptElement>('script[type="application/json"]');
    if (!rootScript) return;

    if (!isMarkmapLoaded()) {
      const loaded = await loadMarkmapScripts();
      if (!loaded) {
        container.innerHTML = '<p class="markmap-error">Failed to load markmap library</p>';
        return;
      }
    }

    if (!isMarkmapLoaded()) {
      setTimeout(() => renderMarkmapContainer(container), 100);
      return;
    }

    try {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      const markmapLib = (window as any).markmap;
      if (!markmapLib) return;
      const { Markmap, Toolbar, deriveOptions } = markmapLib;
      const root = JSON.parse(rootScript.textContent || '{}');
      
      const scripts = container.querySelectorAll<HTMLScriptElement>('script[type="application/json"]');
      const options = scripts[1] ? JSON.parse(scripts[1].textContent || '{}') : {};

      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('width', '100%');
      svg.setAttribute('height', 'auto');
      container.innerHTML = '';
      container.appendChild(svg);

      const markmap = Markmap.create(svg, deriveOptions(options), root);

      if (Toolbar) {
        const toolbar = Toolbar.create(markmap);
        toolbar.setBrand(false);
        
        toolbar.register({
          id: "fullScreen",
          title: "Full Screen View",
          content: Toolbar.icon("M4 9v-4h4v2h-2v2zM4 11v4h4v-2h-2v-2zM16 9v-4h-4v2h2v2zM16 11v4h-4v-2h2v-2z"),
          onClick: () => {
            if (document.fullscreenElement) {
              document.exitFullscreen();
            } else {
              container.requestFullscreen();
            }
          }
        });

        container.addEventListener("fullscreenchange", () => {
          container.classList.toggle("fullscreen", !!document.fullscreenElement);
        });

        toolbar.setItems([...toolbar.items, "fullScreen"]);
        container.appendChild(toolbar.el);
      }

      const resizeObserver = new ResizeObserver(
        debounce(() => {
          svg.style.height = markmap.state.rect.y2 + 'px';
          markmap.fit();
        }, 100)
      );
      resizeObserver.observe(container);

      requestAnimationFrame(() => {
        svg.style.height = markmap.state.rect.y2 + 'px';
        markmap.fit();
      });

      container.dataset.rendered = 'true';
    } catch (error) {
      // eslint-disable-next-line no-console
      console.error('Markmap render error:', error);
      container.innerHTML = '<p class="markmap-error">Failed to render mind map</p>';
    }
  }

  function renderAllMarkmaps() {
    document.querySelectorAll<HTMLElement>('.markmap-wrap').forEach(container => {
      const svg = container.querySelector('svg');
      if (svg && svg.children.length > 0) {
        container.dataset.rendered = 'true';
        return;
      }
      
      const observer = new IntersectionObserver(
        (entries, obs) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              obs.unobserve(entry.target);
              renderMarkmapContainer(entry.target as HTMLElement);
            }
          }
        },
        { rootMargin: '200px' }
      );
      observer.observe(container);
    });
  }

  window.addEventListener('themechange', ((e: CustomEvent<{ isDark: boolean }>) => {
    updateMarkmapTheme(e.detail.isDark);
  }) as EventListener);

  function init() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark' ||
                   document.documentElement.classList.contains('dark');
    updateMarkmapTheme(isDark);
    
    renderAllMarkmaps();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
</script>

<style is:global>
  .markmap-wrap {
    position: relative;
    height: max-content;
    width: 100%;
    min-height: 300px;
    margin: 1.5rem 0;
    border-radius: 0.5rem;
    border: 1px solid var(--border, #e5e7eb);
    overflow: hidden;
  }

  .markmap-wrap.fullscreen {
    background: #ffffff;
  }

  :global(html[data-theme="dark"]) .markmap-wrap {
    border-color: var(--border, #374151);
  }

  :global(html.markmap-dark) .markmap-wrap.fullscreen {
    background: #1a1a1a;
  }

  .markmap-wrap > svg {
    width: 100%;
    height: auto;
    margin: 0;
    padding: 0;
  }

  .markmap-wrap.fullscreen > svg {
    height: 100% !important;
  }

  .mm-toolbar {
    position: absolute;
    right: 0.5em;
    bottom: 0.5em;
  }

  :global(html.markmap-dark) .markmap {
    --markmap-text-color: var(--foreground, #eee);
    --markmap-code-bg: var(--muted, #1a1b26);
    --markmap-circle-open-bg: var(--card, #444);
  }

  .markmap-error {
    color: #ef4444;
    text-align: center;
    padding: 1rem;
  }
</style>