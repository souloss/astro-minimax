---
/**
 * FullHtmlEmbed Component
 * Renders a complete HTML document within an iframe for isolation
 * 
 * Usage in MDX: 
 * <FullHtmlEmbed html={htmlContent} title="Interactive Diagram" />
 * 
 * Or with file path (for build-time reading):
 * <FullHtmlEmbed src="/content/2026-blog.html" title="Architecture Diagram" />
 */

interface Props {
  html?: string;
  src?: string;
  title?: string;
  height?: string;
  allowFullscreen?: boolean;
}

const { 
  html, 
  src, 
  title = "Embedded HTML Content", 
  height = "1600px",
  allowFullscreen = true 
} = Astro.props;

// Security: Sandbox the iframe
const sandboxAttributes = [
  "allow-scripts",
  "allow-same-origin",
  allowFullscreen ? "allow-fullscreen" : "",
].filter(Boolean).join(" ");
---

<div class="full-html-embed-wrapper my-6">
  <div 
    class="relative w-full overflow-hidden rounded-lg border border-border bg-muted/5"
    style={`height: ${height};`}
  >
    <!-- Loading placeholder -->
    <div 
      class="html-placeholder absolute inset-0 flex flex-col items-center justify-center gap-3 transition-opacity duration-300 z-10"
      data-placeholder
    >
      <svg 
        class="text-muted-foreground size-12 animate-pulse" 
        viewBox="0 0 24 24" 
        fill="none" 
        stroke="currentColor" 
        stroke-width="1.5"
        aria-hidden="true"
      >
        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
        <line x1="3" y1="9" x2="21" y2="9"></line>
        <line x1="9" y1="21" x2="9" y2="9"></line>
      </svg>
      <span class="text-muted-foreground text-sm">加载交互内容...</span>
    </div>
    
    <!-- Iframe for isolated rendering -->
    {html ? (
      <iframe
        srcdoc={html}
        class="html-iframe absolute inset-0 h-full w-full rounded-lg border-0 bg-background"
        sandbox={sandboxAttributes}
        title={title}
        loading="lazy"
        onload="this.previousElementSibling.classList.add('opacity-0','pointer-events-none')"
      ></iframe>
    ) : src ? (
      <iframe
        src={src}
        class="html-iframe absolute inset-0 h-full w-full rounded-lg border-0 bg-background"
        sandbox={sandboxAttributes}
        title={title}
        loading="lazy"
        onload="this.previousElementSibling.classList.add('opacity-0','pointer-events-none')"
      ></iframe>
    ) : (
      <div class="absolute inset-0 flex items-center justify-center text-muted-foreground">
        No HTML content provided
      </div>
    )}
  </div>
  
  <!-- Optional expand button for full-screen viewing -->
  {allowFullscreen && (
    <div class="mt-2 flex justify-end">
      <button 
        class="expand-btn text-muted-foreground hover:text-accent text-xs flex items-center gap-1 transition-colors"
        data-expand-title={title}
        aria-label="全屏查看"
      >
        <svg 
          class="size-4" 
          viewBox="0 0 24 24" 
          fill="none" 
          stroke="currentColor" 
          stroke-width="2"
        >
          <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"></path>
        </svg>
        <span>全屏查看</span>
      </button>
    </div>
  )}
</div>

<script>
  function initFullHtmlEmbed() {
    document.querySelectorAll<HTMLButtonElement>('.expand-btn').forEach(btn => {
      if (btn.dataset.initialized) return;
      btn.dataset.initialized = "true";
      
      btn.addEventListener('click', () => {
        const wrapper = btn.closest('.full-html-embed-wrapper');
        const iframe = wrapper?.querySelector('iframe');
        if (!iframe) return;
        
        // Request fullscreen
        if (iframe.requestFullscreen) {
          iframe.requestFullscreen();
        } else if ('webkitRequestFullscreen' in iframe) {
          (iframe as HTMLElement & { webkitRequestFullscreen: () => void }).webkitRequestFullscreen();
        } else if ('msRequestFullscreen' in iframe) {
          (iframe as HTMLElement & { msRequestFullscreen: () => void }).msRequestFullscreen();
        }
      });
    });
  }
  
  initFullHtmlEmbed();
  document.addEventListener('astro:page-load', initFullHtmlEmbed);
</script>

<style>
  .full-html-embed-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 0.5rem;
  }
  
  .html-placeholder {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(var(--color-muted-foreground), 0.05),
      transparent
    );
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }
  
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  
  .expand-btn {
    cursor: pointer;
  }
</style>