---
import { randomUUID } from "node:crypto";
import VizContainer from "./VizContainer.astro";

interface Props {
  content: string;
}

const { content } = Astro.props;
const uniqueId = `markmap-${randomUUID()}`;
---

<VizContainer minHeight="200px">
  <div class="markmap-wrapper" data-markmap-id={uniqueId} data-viz-type="markmap">
    <svg id={`${uniqueId}-svg`} class="markmap-svg" style="width: 100%; min-height: 200px;"></svg>
    <div class="markmap-placeholder">
      <svg class="size-8 animate-pulse text-foreground-soft/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <circle cx="12" cy="12" r="3" /><line x1="12" y1="3" x2="12" y2="9" /><line x1="12" y1="15" x2="12" y2="21" />
        <line x1="3" y1="12" x2="9" y2="12" /><line x1="15" y1="12" x2="21" y2="12" />
      </svg>
    </div>
    <script
      is:inline
      type="application/json"
      class="markmap-content"
      set:html={JSON.stringify(content)}
    />
  </div>
</VizContainer>

<script>
  import "../scripts/markmap-renderer.ts";
</script>

<style is:global>
  .markmap-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100%;
    padding: 1rem;
    position: relative;
  }

  .markmap-svg {
    width: 100%;
    min-height: 200px;
    transition: color 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .markmap-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
  }

  .markmap-error {
    color: #ef4444;
    text-align: center;
    padding: 1rem;
  }

  :global(html[data-theme="dark"]) .markmap-error {
    color: #f87171;
  }
</style>
