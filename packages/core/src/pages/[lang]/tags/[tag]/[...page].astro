---
import type { GetStaticPaths, Page } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Main from "../../../../layouts/Main.astro";
import Layout from "../../../../layouts/Layout.astro";
import Header from "../../../../components/nav/Header.astro";
import Footer from "../../../../components/nav/Footer.astro";
import PostsContainer from "../../../../components/ui/PostsContainer.astro";
import Pagination from "../../../../components/nav/Pagination.astro";
import getUniqueTags from "../../../../utils/getUniqueTags";
import getPostsByTag from "../../../../utils/getPostsByTag";
import { getPostsByLang } from "../../../../utils/getPostsByLang";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../../../utils/i18n";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getCollection("blog");
  return (["zh", "en"] as const).flatMap(lang => {
    const langPosts = getPostsByLang(posts, lang);
    const tags = getUniqueTags(langPosts);
    return tags.flatMap(({ tag, tagName }) => {
      const tagPosts = getPostsByTag(langPosts, tag);
      return paginate(tagPosts, {
        params: { lang, tag },
        props: { tagName },
        pageSize: SITE.postPerPage,
      });
    });
  });
}) satisfies GetStaticPaths;

type Props = { page: Page<CollectionEntry<"blog">>; tagName: string };
const { page, tagName } = Astro.props as Props;
const lang = (Astro.params.lang ?? "zh") as "zh" | "en";
const tag = Astro.params.tag ?? "";
---

<Layout
  lang={lang}
  title={`${t("search.tags", lang)}: ${tagName} | ${SITE.title}`}
>
  <Header lang={lang} />
  <Main
    pageTitle={[`${t("search.tags", lang)}:`, tagName]}
    titleTransition={tag}
    pageDesc={t("main.tagDesc", lang).replace("{tag}", tagName)}
  >
    <PostsContainer posts={page.data} lang={lang} />
  </Main>

  <Pagination page={page} lang={lang} />

  <Footer lang={lang} noMarginTop={page.lastPage > 1} />
</Layout>
