---
import { getCollection } from "astro:content";
import Main from "../../../layouts/Main.astro";
import Layout from "../../../layouts/Layout.astro";
import TagCloud from "../../../components/ui/TagCloud.astro";
import Header from "../../../components/nav/Header.astro";
import Footer from "../../../components/nav/Footer.astro";
import getTagsWithCount from "../../../utils/getTagsWithCount";
import getPostsByLang from "../../../utils/getPostsByLang";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../../utils/i18n";

export const getStaticPaths = () => [
  { params: { lang: "zh" } },
  { params: { lang: "en" } },
];

const { lang } = Astro.params as { lang: "zh" | "en" };

const posts = await getCollection("blog");
const langPosts = getPostsByLang(posts, lang);
const tags = getTagsWithCount(langPosts);

const counts = tags.map(tag => tag.count);
const maxCount = Math.max(...counts, 1);
const minCount = Math.min(...counts, 0);
const totalPosts = tags.reduce((acc, tag) => acc + tag.count, 0);
---

<Layout lang={lang} title={`${t("nav.tags", lang)} | ${SITE.title}`}>
  <Header lang={lang} />
  <Main
    pageTitle={t("nav.tags", lang)}
    pageDesc={t("main.allTags", lang)}
    data-lang={lang}
  >
    <!-- Stats Overview -->
    <div class="mb-8 flex items-center gap-6 text-sm text-muted">
      <div class="flex items-center gap-2">
        <svg class="size-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z" />
          <line x1="7" y1="7" x2="7.01" y2="7" />
        </svg>
        <span class="font-medium text-foreground">{tags.length}</span>
        <span>{t("tags.tags", lang)}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="size-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
          <polyline points="14 2 14 8 20 8" />
        </svg>
        <span class="font-medium text-foreground">{totalPosts}</span>
        <span>{t("tags.taggedPosts", lang)}</span>
      </div>
    </div>

    <!-- Tag Cloud Container -->
    <div class="card-animate overflow-hidden rounded-2xl border border-border/50 bg-card/60 backdrop-blur-md p-6 sm:p-8">
      <div class="flex flex-wrap items-center justify-center gap-3">
        {
          tags.map(({ tag, tagName, count }) => (
            <TagCloud
              tag={tag}
              tagName={tagName}
              count={count}
              maxCount={maxCount}
              minCount={minCount}
              lang={lang}
            />
          ))
        }
      </div>

      <!-- Size Legend -->
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4 border-t border-border/50 pt-6 text-xs text-muted">
        <span>{t("tags.sizeLegend", lang)}</span>
        <div class="flex items-center gap-2">
          <span>{t("tags.less", lang)}</span>
          <div class="flex items-center gap-1.5">
            <div class="size-2 rounded-full bg-foreground/40"></div>
            <div class="size-3 rounded-full bg-foreground/60"></div>
            <div class="size-4 rounded-full bg-foreground/80"></div>
            <div class="size-5 rounded-full bg-foreground"></div>
          </div>
          <span class="text-sm font-medium">{t("tags.more", lang)}</span>
        </div>
      </div>
    </div>
  </Main>
  <Footer lang={lang} />
</Layout>
