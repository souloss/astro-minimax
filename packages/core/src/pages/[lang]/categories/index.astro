---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Main from "../../../layouts/Main.astro";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/nav/Header.astro";
import Footer from "../../../components/nav/Footer.astro";
import { getCategoryTree } from "../../../utils/getUniqueCategories";
import type { CategoryTreeNode } from "../../../utils/getUniqueCategories";
import { getPostsByLang } from "../../../utils/getPostsByLang";
import { getCategoryUrl } from "../../../utils/getCategoryPath";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../../utils/i18n";

export const getStaticPaths = (() => [
  { params: { lang: "zh" } },
  { params: { lang: "en" } },
]) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: "zh" | "en" };

const posts = await getCollection("blog");
const langPosts = getPostsByLang(posts, lang);
const tree = getCategoryTree(langPosts);

function countAll(node: CategoryTreeNode): number {
  return node.count + node.children.reduce((s, c) => s + countAll(c), 0);
}

const totalCategories = tree.length;
const totalPosts = tree.reduce((sum, node) => sum + countAll(node), 0);
---

<Layout lang={lang} title={`${t("nav.categories", lang)} | ${SITE.title}`}>
  <Header lang={lang} />
  <Main
    pageTitle={t("nav.categories", lang)}
    pageDesc={t("main.allArticles", lang)}
    data-lang={lang}
  >
    <!-- Stats Overview -->
    <div class="mb-8 flex items-center gap-6 text-sm text-muted">
      <div class="flex items-center gap-2">
        <svg class="size-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
        </svg>
        <span>{totalCategories} {lang === "zh" ? "个分类" : "categories"}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="size-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
          <polyline points="14 2 14 8 20 8" />
        </svg>
        <span>{totalPosts} {lang === "zh" ? "篇文章" : "posts"}</span>
      </div>
    </div>

    <!-- Category Grid -->
    <div class="grid gap-4 sm:grid-cols-2">
      {
        tree.map((node, index) => {
          const postCount = countAll(node);
          const childCount = node.children.length;
          const delay = Math.min(index * 80, 400);
          
          return (
            <article
              class="group card-animate cursor-pointer overflow-hidden rounded-2xl border border-border/50 bg-card/60 backdrop-blur-md transition-all duration-300 ease-out hover:border-accent/25 hover:bg-card-hover hover:shadow-xl hover:shadow-shadow-elevated/10 hover:-translate-y-1"
              style={`animation-delay: ${delay}ms`}
            >
              <a
                href={getCategoryUrl(lang, node.fullPath)}
                class="block p-5 sm:p-6"
              >
                <!-- Header -->
                <div class="flex items-start justify-between gap-4">
                  <div class="flex items-center gap-3">
                    <div class="flex size-10 items-center justify-center rounded-xl bg-accent/10 text-accent transition-colors group-hover:bg-accent/15">
                      <svg
                        class="size-5"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
                      </svg>
                    </div>
                    <div>
                      <h2 class="text-lg font-semibold text-foreground transition-colors group-hover:text-accent">
                        {node.name}
                      </h2>
                      <p class="mt-0.5 text-sm text-muted">
                        {postCount} {lang === "zh" ? "篇" : "posts"}
                        {childCount > 0 && <span class="opacity-60"> · {childCount} {lang === "zh" ? "个子分类" : "subcategories"}</span>}
                      </p>
                    </div>
                  </div>
                  
                  <!-- Count Badge -->
                  <span class="flex size-8 items-center justify-center rounded-full bg-accent/10 text-sm font-medium text-accent transition-all group-hover:bg-accent group-hover:text-white">
                    {postCount}
                  </span>
                </div>

                <!-- Children Tags -->
                {node.children.length > 0 && (
                  <div class="mt-4 flex flex-wrap gap-2 border-t border-border/50 pt-4">
                    {node.children.slice(0, 4).map(child => (
                      <span
                        class="inline-flex items-center gap-1.5 rounded-lg bg-muted/40 px-2.5 py-1 text-xs font-medium text-foreground-soft transition-colors hover:bg-accent/10 hover:text-accent"
                      >
                        <svg class="size-3 opacity-60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                        </svg>
                        {child.name}
                        <span class="opacity-50">({countAll(child)})</span>
                      </span>
                    ))}
                    {node.children.length > 4 && (
                      <span class="inline-flex items-center rounded-lg bg-muted/40 px-2.5 py-1 text-xs text-muted">
                        +{node.children.length - 4} {lang === "zh" ? "更多" : "more"}
                      </span>
                    )}
                  </div>
                )}

                <!-- Arrow Indicator -->
                <div class="mt-4 flex items-center justify-end">
                  <svg class="size-5 text-muted opacity-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </div>
              </a>
            </article>
          );
        })
      }
    </div>

    {
      tree.length === 0 && (
        <div class="flex flex-col items-center justify-center py-16 text-center">
          <div class="flex size-16 items-center justify-center rounded-2xl bg-muted/30">
            <svg class="size-8 text-muted" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z" />
            </svg>
          </div>
          <p class="mt-4 text-muted">
            {t("main.noCategories", lang)}
          </p>
        </div>
      )
    }
  </Main>
  <Footer lang={lang} />
</Layout>
