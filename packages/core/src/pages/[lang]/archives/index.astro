---
import { getCollection } from "astro:content";
import Main from "../../../layouts/Main.astro";
import Layout from "../../../layouts/Layout.astro";
import Header from "../../../components/nav/Header.astro";
import Footer from "../../../components/nav/Footer.astro";
import PostsContainer from "../../../components/ui/PostsContainer.astro";
import getPostsByGroupCondition from "../../../utils/getPostsByGroupCondition";
import getPostsByLang from "../../../utils/getPostsByLang";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../../utils/i18n";

export async function getStaticPaths() {
  if (!SITE.showArchives) return [];
  return [{ params: { lang: "zh" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: "zh" | "en" };

const posts = await getCollection("blog", ({ data }) => !data.draft);
const langPosts = getPostsByLang(posts, lang);

const months =
  lang === "zh"
    ? [
        "一月",
        "二月",
        "三月",
        "四月",
        "五月",
        "六月",
        "七月",
        "八月",
        "九月",
        "十月",
        "十一月",
        "十二月",
      ]
    : [
        "January",
        "February",
        "March",
        "April",
        "May",
        "June",
        "July",
        "August",
        "September",
        "October",
        "November",
        "December",
      ];

const totalPosts = langPosts.length;
const years = getPostsByGroupCondition(langPosts, post =>
  post.data.pubDatetime.getFullYear()
);
const yearCount = Object.keys(years).length;
---

<Layout lang={lang} title={`${t("nav.archives", lang)} | ${SITE.title}`}>
  <Header lang={lang} />
  <Main
    pageTitle={t("nav.archives", lang)}
    pageDesc={t("main.allArchived", lang)}
    data-lang={lang}
  >
    <!-- Stats Overview -->
    <div class="mb-8 flex items-center gap-6 text-sm text-muted">
      <div class="flex items-center gap-2">
        <svg class="size-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z" />
          <polyline points="14 2 14 8 20 8" />
        </svg>
        <span class="font-medium text-foreground">{totalPosts}</span>
        <span>{t("archives.posts", lang)}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="size-4 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
        <span class="font-medium text-foreground">{yearCount}</span>
        <span>{t("archives.years", lang)}</span>
      </div>
    </div>

    <!-- Timeline -->
    <div class="relative">
      {/* Center timeline line */}
      <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gradient-to-b from-accent/40 via-accent/20 to-transparent md:left-1/2 md:-translate-x-px"></div>

      {
        Object.entries(
          getPostsByGroupCondition(langPosts, post =>
            post.data.pubDatetime.getFullYear()
          )
        )
          .sort(([yearA], [yearB]) => Number(yearB) - Number(yearA))
          .map(([year, yearGroup]) => (
            <div class="relative pb-12">
              {/* Year Badge */}
              <div class="mb-8 flex items-center md:justify-center">
                <div class="relative z-10 ml-10 flex items-center gap-3 rounded-2xl border border-accent/20 bg-accent/10 px-5 py-2.5 backdrop-blur-sm md:ml-0">
                  <svg class="size-5 text-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                    <line x1="16" y1="2" x2="16" y2="6" />
                    <line x1="8" y1="2" x2="8" y2="6" />
                    <line x1="3" y1="10" x2="21" y2="10" />
                  </svg>
                  <span class="text-lg font-bold text-accent">{year}</span>
                  <span class="rounded-full bg-accent/20 px-2.5 py-0.5 text-sm font-medium text-accent">
                    {yearGroup.length}
                  </span>
                </div>
              </div>

              {/* Months */}
              <div class="ml-10 border-l-2 border-border/50 pl-6 md:ml-0 md:border-l-0 md:pl-0">
                {Object.entries(
                  getPostsByGroupCondition(
                    yearGroup,
                    post => post.data.pubDatetime.getMonth() + 1
                  )
                )
                  .sort(([monthA], [monthB]) => Number(monthB) - Number(monthA))
                  .map(([month, monthGroup]) => (
                    <div class="relative mb-8 last:mb-0">
                      {/* Month Header */}
                      <div class="mb-4 flex items-center gap-3">
                        <div class="absolute left-0 size-3 -translate-x-1/2 rounded-full bg-accent/50 ring-4 ring-background md:relative md:left-0 md:translate-x-0" />
                        <h3 class="ml-4 text-lg font-semibold text-foreground md:ml-0">
                          {months[Number(month) - 1]}
                          <span class="ml-2 text-sm font-normal text-muted">
                            ({monthGroup.length} {t("archives.posts", lang)})
                          </span>
                        </h3>
                      </div>

                      {/* Posts */}
                      <ul class="ml-6 md:ml-4" data-posts-grid>
                        <PostsContainer
                          posts={monthGroup.sort(
                            (a, b) =>
                              Math.floor(
                                new Date(b.data.pubDatetime).getTime() / 1000
                              ) -
                              Math.floor(
                                new Date(a.data.pubDatetime).getTime() / 1000
                              )
                          )}
                          lang={lang}
                        />
                      </ul>
                    </div>
                  ))}
              </div>
            </div>
          ))
      }
    </div>
  </Main>
  <Footer lang={lang} />
</Layout>
