---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { slugifyStr } from "../../utils/slugify";
import { getLocalizedPostPath } from "../../utils/getPath";
import { getReadingTime } from "../../utils/getReadingTime";

export interface PostItemData {
  title: string;
  description: string;
  href: string;
  dateStr: string;
  dateIso: string;
  category: string | undefined;
  tags: string[];
  readingMinutes: number;
  coverSrc: string | undefined;
  langLabel: string;
  viewTransitionName: string;
}

export function getAnimationDelay(index: number): string {
  return `${Math.min(index * 60, 400)}ms`;
}

export function formatPostData(
  post: CollectionEntry<"blog">,
  lang: string,
  datetime: ReturnType<typeof import("dayjs").Dayjs>
): PostItemData {
  const { id, data, body, filePath } = post;
  const { title, description, category, ogImage, tags } = data;
  
  const href = getLocalizedPostPath(lang, id, filePath);
  const { minutes: readingMinutes } = getReadingTime(body ?? "");
  
  let coverSrc: string | undefined;
  if (ogImage && typeof ogImage === "object" && "src" in ogImage) {
    coverSrc = (ogImage as ImageMetadata).src;
  } else if (typeof ogImage === "string" && ogImage.startsWith("http")) {
    coverSrc = ogImage;
  }
  
  const langLabel = id.startsWith("en/") ? "English" : "中文";
  const dateStr = lang === "zh"
    ? datetime.format("YYYY 年 M 月 D 日")
    : datetime.format("MMM D, YYYY");
  
  return {
    title,
    description,
    href,
    dateStr,
    dateIso: datetime.toISOString(),
    category,
    tags: tags || [],
    readingMinutes,
    coverSrc,
    langLabel,
    viewTransitionName: slugifyStr(title.replaceAll(".", "-")),
  };
}