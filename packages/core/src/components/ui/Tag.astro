---
import IconHash from "../../assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  lang?: string;
};

const { tag, tagName, size = "lg", lang } = Astro.props;
const tagHref = lang ? `/${lang}/tags/${tag}/` : `/tags/${tag}/`;
---

<li>
  <a
    href={tagHref}
    transition:name={tag}
    class:list={[
      "inline-flex items-center gap-1.5 rounded-xl",
      "border border-border/50 bg-muted/40",
      "font-medium text-foreground-soft",
      "transition-all duration-200 ease-out",
      "hover:border-accent/30 hover:bg-accent/10 hover:text-accent",
      "focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent",
      { "px-3 py-1.5 text-sm": size === "sm" },
      { "px-4 py-2 text-base": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-60",
        { "size-4": size === "lg" },
        { "size-3.5": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>