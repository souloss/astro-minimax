---
/**
 * PostCard 组件 - 统一的文章卡片组件
 * 
 * 支持三种布局模式：
 * - card: 卡片布局，标题优先，完整元信息，适合阅读型内容
 * - grid: 网格布局，高信息密度，快速浏览，适合图文并茂
 * - list: 列表布局，极简紧凑，适合归档/大量文章
 * 
 * 统一交互特性：
 * - 标题 hover 下划线动画
 * - 卡片整体可点击
 * - 元信息可点击跳转
 */
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { slugifyStr } from "../../utils/slugify";
import { getLocalizedPostPath } from "../../utils/getPath";
import { getReadingTime } from "../../utils/getReadingTime";
import { t } from "../../utils/i18n";
import PostMeta from "./PostMeta.astro";
import dayjs from "dayjs";
import utcPlugin from "dayjs/plugin/utc";
import timezonePlugin from "dayjs/plugin/timezone";
import { SITE } from "virtual:astro-minimax/config";

dayjs.extend(utcPlugin);
dayjs.extend(timezonePlugin);

type LayoutMode = "card" | "grid" | "list";

type Props = {
  variant?: "h2" | "h3";
  lang?: string;
  priority?: boolean;
  index?: number;
  /** 布局模式 */
  layout?: LayoutMode;
} & CollectionEntry<"blog">;

const {
  variant: Heading = "h2",
  id,
  data,
  body,
  filePath,
  lang = "zh",
  priority = false,
  index = 0,
  layout = "card",
} = Astro.props;

const { title, description, category, cover, ogImage, tags, pubDatetime, modDatetime, timezone } = data;
const postHref = getLocalizedPostPath(lang, id, filePath);
const { minutes: readingMinutes } = getReadingTime(body ?? "");

// 封面图片：优先使用 cover，fallback 到 ogImage
let coverSrc: string | undefined;
const coverImage = cover || ogImage;
if (coverImage && typeof coverImage === "object" && "src" in coverImage) {
  coverSrc = (coverImage as ImageMetadata).src;
} else if (typeof coverImage === "string" && coverImage.startsWith("http")) {
  coverSrc = coverImage;
}

const isModified = modDatetime && modDatetime > pubDatetime;
const datetime = dayjs(isModified ? modDatetime : pubDatetime).tz(timezone || SITE.timezone);
const dateStr = lang === "zh"
  ? datetime.format("YYYY 年 M 月 D 日")
  : datetime.format("MMM D, YYYY");

const animationDelay = Math.min(index * 80, 400);
---

{/* ============================================
    CARD 布局：标题优先，完整元信息
    ============================================ */}
{layout === "card" && (
  <li class="group h-full w-full" style={`--delay: ${animationDelay}ms`}>
    <article
      class="post-card card-animate relative flex h-full w-full flex-col overflow-hidden
             border border-border/50 bg-card/60 backdrop-blur-md cursor-pointer
             transition-all duration-300 ease-out
             hover:border-accent/30 hover:bg-card-hover 
             hover:shadow-xl hover:shadow-shadow-elevated/10 hover:-translate-y-0.5
             focus-within:outline-2 focus-within:outline-dashed focus-within:outline-accent"
      style={`animation-delay: var(--delay)`}
      data-post-href={postHref}
    >
      {/* 标题区域 */}
      <div class="p-5 pb-0">
        <a href={postHref} class="block outline-none" onclick="event.stopPropagation()">
          <Heading
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            class="title-with-underline inline text-lg font-bold leading-snug tracking-tight text-foreground
                   transition-colors duration-200 group-hover:text-accent"
          >
            {title}
          </Heading>
        </a>
      </div>

      {/* 封面图片 */}
      {coverSrc && (
        <div class="px-5 mt-4">
          <div class="relative aspect-[16/9] overflow-hidden rounded-xl">
            <img
              src={coverSrc}
              alt=""
              class="h-full w-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
              loading={priority ? "eager" : "lazy"}
              decoding="async"
              fetchpriority={priority ? "high" : undefined}
              width="800"
              height="450"
            />
          </div>
        </div>
      )}

      {/* 摘要 */}
      <div class="p-5 pt-4 flex-1">
        <p class="line-clamp-3 text-sm leading-relaxed text-foreground-soft">
          {description}
        </p>
      </div>

      {/* 分隔线 */}
      <div class="mx-5 border-t border-border/50"></div>

      {/* 元信息 */}
      <div class="p-5 pt-3">
        <PostMeta
          mode="full"
          lang={lang}
          dateStr={dateStr}
          dateIso={datetime.toISOString()}
          readingMinutes={readingMinutes}
          category={category}
          tags={tags}
        />
      </div>
    </article>
  </li>
)}

{/* ============================================
    GRID 布局：高信息密度
    ============================================ */}
{layout === "grid" && (
  <li class="group h-full" style={`--delay: ${animationDelay}ms`}>
    <article
      class="post-card card-animate grid-card relative flex h-full flex-col overflow-hidden
             border border-border/50 bg-card/60 backdrop-blur-md cursor-pointer
             transition-all duration-300 ease-out
             hover:border-accent/30 hover:bg-card-hover 
             hover:shadow-lg hover:shadow-shadow-elevated/10 hover:-translate-y-0.5
             focus-within:outline-2 focus-within:outline-dashed focus-within:outline-accent"
      style={`animation-delay: var(--delay)`}
      data-post-href={postHref}
    >
      {/* 封面图片 */}
      {coverSrc && (
        <div class="relative w-full h-36 sm:h-40 overflow-hidden shrink-0">
          <img
            src={coverSrc}
            alt=""
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            loading={priority ? "eager" : "lazy"}
            decoding="async"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-background/60 via-transparent to-transparent"></div>
        </div>
      )}

      {/* 内容区域 */}
      <div class="flex flex-col flex-1 p-4 min-h-0">
        {/* 标题 */}
        <a href={postHref} class="block outline-none" onclick="event.stopPropagation()">
          <Heading
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            class="title-with-underline inline text-base font-bold text-foreground line-clamp-2 leading-snug
                   transition-colors duration-200 group-hover:text-accent"
          >
            {title}
          </Heading>
        </a>
        
        {/* 摘要 */}
        <p class="mt-2 text-sm text-foreground-soft/80 line-clamp-2 leading-relaxed flex-1">
          {description}
        </p>
        
        {/* 分隔线 */}
        <div class="my-3 border-t border-border/50"></div>
        
        {/* 元信息 */}
        <PostMeta
          mode="compact"
          lang={lang}
          dateStr={dateStr}
          dateIso={datetime.toISOString()}
          readingMinutes={readingMinutes}
          category={category}
        />
      </div>
    </article>
  </li>
)}

{/* ============================================
    LIST 布局：极简紧凑
    ============================================ */}
{layout === "list" && (
  <li class="group border-b border-border/50 hover:bg-card/30 transition-colors duration-200" style={`--delay: ${animationDelay}ms`}>
    <article
      class="post-card card-animate relative flex items-start gap-3 sm:gap-4 py-4 px-2 cursor-pointer"
      style={`animation-delay: var(--delay)`}
      data-post-href={postHref}
    >
      {/* 缩略图 */}
      {coverSrc && (
        <div class="shrink-0 hidden sm:block w-20 h-14 overflow-hidden rounded-lg">
          <img
            src={coverSrc}
            alt=""
            class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
            loading={priority ? "eager" : "lazy"}
            decoding="async"
          />
        </div>
      )}
      
      {/* 日期区 */}
      <div class={`shrink-0 w-20 pt-0.5 ${coverSrc ? "sm:hidden" : ""}`}>
        <time class="block text-xs text-muted">{dateStr}</time>
      </div>
      
      {/* 主内容 */}
      <div class="flex-1 min-w-0">
        {/* 标题 */}
        <a href={postHref} class="block outline-none" onclick="event.stopPropagation()">
          <Heading
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            class="title-with-underline inline text-sm font-bold text-foreground line-clamp-1
                   transition-colors duration-200 group-hover:text-accent"
          >
            {title}
          </Heading>
        </a>
        
        {/* 摘要 */}
        <p class="mt-1 text-xs text-foreground-soft/80 line-clamp-1">{description}</p>
        
        {/* 元信息 */}
        <div class="mt-1.5 flex flex-wrap items-center gap-2 text-xs text-muted">
          {coverSrc && (
            <>
              <time class="text-muted">{dateStr}</time>
              <span class="text-border">·</span>
            </>
          )}
          <span>{readingMinutes} {lang === "zh" ? "分钟" : "min"}</span>
          {category && (
            <>
              <span class="text-border">·</span>
              <a 
                href={`/${lang}/categories/${encodeURIComponent(category)}/`}
                class="meta-link text-accent hover:underline"
                onclick="event.stopPropagation()"
              >
                {category}
              </a>
            </>
          )}
          {tags && tags.slice(0, 2).map((tag: string) => (
            <a
              href={`/${lang}/tags/${encodeURIComponent(tag)}/`}
              class="meta-link px-1.5 py-0.5 rounded bg-muted/50 text-foreground-soft hover:text-accent"
              onclick="event.stopPropagation()"
            >
              #{tag}
            </a>
          ))}
        </div>
      </div>
    </article>
  </li>
)}

<style>
  .card-animate {
    opacity: 0;
    animation: card-reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }
  
  @keyframes card-reveal {
    0% {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  /* 卡片基础样式 */
  .post-card {
    border-radius: var(--radius-3xl);
  }

  /* 网格卡片高度 */
  .grid-card {
    min-height: 260px;
  }

  /* 标题 hover 下划线动画 */
  .title-with-underline {
    position: relative;
    text-decoration: none;
  }

  .title-with-underline::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--accent);
    transition: width 0.3s cubic-bezier(0.16, 1, 0.3, 1);
    border-radius: 1px;
  }

  .group:hover .title-with-underline::after {
    width: 100%;
  }

  /* 元信息链接样式 */
  .meta-link {
    text-decoration: none;
  }

  .meta-link:hover {
    text-decoration: none;
  }

  /* 卡片点击交互 */
  [data-post-href] {
    user-select: none;
  }

  [data-post-href]:active {
    transform: scale(0.995);
  }
</style>

<script>
  // 点击卡片任意区域跳转到文章页面
  document.addEventListener('click', (e) => {
    const article = (e.target as HTMLElement).closest('article[data-post-href]');
    if (article && !(e.target as HTMLElement).closest('.meta-link') && !(e.target as HTMLElement).closest('a[onclick]')) {
      const href = article.getAttribute('data-post-href');
      if (href) {
        window.location.href = href;
      }
    }
  });
</script>