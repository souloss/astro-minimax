---
import type { CollectionEntry } from "astro:content";
import type { ImageMetadata } from "astro";
import { slugifyStr } from "../../utils/slugify";
import { getLocalizedPostPath } from "../../utils/getPath";
import { getReadingTime } from "../../utils/getReadingTime";
import { t } from "../../utils/i18n";
import IconArrowRight from "../../assets/icons/IconArrowRight.svg";

type Props = {
  variant?: "h2" | "h3";
  compact?: boolean;
  lang?: string;
  priority?: boolean;
  index?: number;
} & CollectionEntry<"blog">;

const {
  variant: Heading = "h2",
  compact = false,
  id,
  data,
  body,
  filePath,
  lang = "zh",
  priority = false,
  index = 0,
} = Astro.props;

const { title, description, category, ogImage, tags, pubDatetime, modDatetime, timezone } = data;
const postHref = getLocalizedPostPath(lang, id, filePath);
const { minutes: readingMinutes } = getReadingTime(body ?? "");

let coverSrc: string | undefined;
if (ogImage && typeof ogImage === "object" && "src" in ogImage) {
  coverSrc = (ogImage as ImageMetadata).src;
} else if (typeof ogImage === "string" && ogImage.startsWith("http")) {
  coverSrc = ogImage;
}

const langLabel = id.startsWith("en/") ? "English" : "中文";

import dayjs from "dayjs";
import utcPlugin from "dayjs/plugin/utc";
import timezonePlugin from "dayjs/plugin/timezone";
import { SITE } from "virtual:astro-minimax/config";

dayjs.extend(utcPlugin);
dayjs.extend(timezonePlugin);

const isModified = modDatetime && modDatetime > pubDatetime;
const datetime = dayjs(isModified ? modDatetime : pubDatetime).tz(timezone || SITE.timezone);
const dateStr = lang === "zh"
  ? datetime.format("YYYY 年 M 月 D 日")
  : datetime.format("MMM D, YYYY");

const animationDelay = Math.min(index * 80, 400);
---

{compact ? (
  <li class="group" style={`--delay: ${animationDelay}ms`}>
    <a
      href={postHref}
      class="card-animate block border border-border/60 bg-card/70 p-4 
             backdrop-blur-sm transition-all duration-300 ease-out
             hover:border-accent/30 hover:bg-card-hover hover:shadow-lg hover:shadow-shadow-elevated/20
             focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent"
      style={`animation-delay: var(--delay); border-radius: var(--card-radius, 1rem)`}
    >
      {category && (
        <span class="mb-1.5 inline-block text-xs font-medium tracking-wide text-accent/90">
          {category}
        </span>
      )}
      <Heading
        style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
        class="text-base font-semibold text-foreground transition-colors duration-200 group-hover:text-accent"
      >
        {title}
      </Heading>
      <p class="mt-1.5 line-clamp-1 text-sm leading-relaxed text-foreground-soft">{description}</p>
      <div class="mt-3 flex items-center gap-2.5 text-xs text-muted">
        <time datetime={datetime.toISOString()} class="font-medium">{dateStr}</time>
        <span class="text-border-strong">·</span>
        <span class="reading-time">{t("post.readingTime", lang).replace("{min}", String(readingMinutes))}</span>
      </div>
    </a>
  </li>
) : (
  <li class="group h-full" style={`--delay: ${animationDelay}ms`}>
    <a
      href={postHref}
      class="card-animate relative flex h-full min-h-[220px] overflow-hidden 
             border border-border/50 bg-card/60 backdrop-blur-md
             transition-all duration-400 ease-out
             hover:border-accent/25 hover:bg-card-hover 
             hover:shadow-2xl hover:shadow-shadow-elevated/15 hover:-translate-y-1
             focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent"
      style={`animation-delay: var(--delay); border-radius: var(--card-radius, 1.25rem)`}
    >
      {coverSrc ? (
        <div class="absolute inset-0">
          <img
            src={coverSrc}
            alt=""
            class="h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
            loading={priority ? "eager" : "lazy"}
            decoding="async"
            fetchpriority={priority ? "high" : undefined}
            width="800"
            height="450"
          />
          <div class="absolute inset-0 bg-gradient-to-br from-black/85 via-black/65 to-black/40" />
        </div>
      ) : (
        <div class="absolute inset-0 bg-gradient-to-br from-card via-surface to-card opacity-80" />
      )}

      <div class={`relative z-10 flex w-full flex-col justify-between p-5 sm:p-6 ${coverSrc ? "text-white" : ""}`}>
        <div>
          <div class="flex items-center gap-2.5">
            <time
              datetime={datetime.toISOString()}
              class:list={[
                "text-xs font-medium tracking-wide",
                coverSrc ? "text-white/75" : "text-foreground-soft"
              ]}
            >
              {dateStr}
            </time>
            {category && (
              <>
                <span class:list={[coverSrc ? "text-white/30" : "text-border-strong"]}>·</span>
                <span class:list={[
                  "text-xs font-medium tracking-wide",
                  coverSrc ? "text-white/80" : "text-accent"
                ]}>
                  {category}
                </span>
              </>
            )}
          </div>

          <Heading
            style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}
            class:list={[
              "mt-3 text-lg font-bold leading-snug tracking-tight sm:text-xl",
              coverSrc ? "text-white" : "text-foreground",
              "transition-colors duration-200 group-hover:text-accent"
            ]}
          >
            {title}
          </Heading>

          <p class:list={[
            "mt-2 line-clamp-2 text-sm leading-relaxed",
            coverSrc ? "text-white/70" : "text-foreground-soft"
          ]}>
            {description}
          </p>
        </div>

        <div class="mt-5 flex flex-wrap items-end justify-between gap-3">
          <div class="flex flex-wrap items-center gap-2.5">
            <span class:list={[
              "reading-time flex items-center gap-1.5 text-xs",
              coverSrc ? "text-white/65" : "text-muted"
            ]}>
              <svg class="size-3.5 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" />
              </svg>
              {readingMinutes} min
            </span>

            <span class:list={[
              "flex items-center gap-1.5 text-xs",
              coverSrc ? "text-white/65" : "text-muted"
            ]}>
              <svg class="size-3.5 opacity-80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" /><path d="M2 12h20" /><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
              {langLabel}
            </span>

            {tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5">
                {tags.slice(0, 3).map((tag: string) => (
                  <span class:list={[
                    "rounded-lg px-2 py-0.5 text-xs font-medium",
                    coverSrc
                      ? "bg-white/15 text-white/75 backdrop-blur-sm"
                      : "bg-muted/70 text-foreground-soft"
                  ]}>
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>

          <IconArrowRight class:list={[
            "size-5 shrink-0 transition-all duration-300 group-hover:translate-x-1 group-hover:opacity-100",
            "rtl:rotate-180 rtl:group-hover:-translate-x-1",
            coverSrc ? "text-white/50 opacity-70" : "text-muted opacity-60"
          ]} />
        </div>
      </div>
    </a>
  </li>
)}

<style>
  .card-animate {
    opacity: 0;
    animation: card-reveal 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }
  
  @keyframes card-reveal {
    0% {
      opacity: 0;
      transform: translateY(16px) scale(0.98);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  
  .duration-400 {
    transition-duration: 400ms;
  }
</style>