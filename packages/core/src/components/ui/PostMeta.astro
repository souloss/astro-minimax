---
/**
 * PostMeta - 统一的文章元信息展示组件
 * 
 * 用于卡片布局和文章详情页，保持一致的元信息展示风格
 */
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../utils/i18n";

type MetaMode = "full" | "compact" | "article";

interface Props {
  /** 展示模式：full=完整，compact=紧凑，article=文章详情页 */
  mode?: MetaMode;
  /** 语言 */
  lang?: string;
  /** 作者名称（可选，默认使用 SITE.author） */
  author?: string;
  /** 发布日期字符串 */
  dateStr?: string;
  /** ISO 日期格式 */
  dateIso?: string;
  /** 阅读时长（分钟） */
  readingMinutes?: number;
  /** 字数 */
  wordCount?: number;
  /** 分类 */
  category?: string;
  /** 标签列表 */
  tags?: string[];
  /** 是否显示作者 */
  showAuthor?: boolean;
}

const {
  mode = "full",
  lang = "zh",
  author = SITE.author,
  dateStr,
  dateIso,
  readingMinutes,
  wordCount,
  category,
  tags = [],
  showAuthor = true,
} = Astro.props;

const isZh = lang === "zh";
const minutesText = isZh ? "分钟" : "min";
const wordsText = isZh ? "字" : "words";

// 生成分类 URL
const categoryUrl = category ? `/${lang}/categories/${encodeURIComponent(category)}/` : null;

// 生成标签 URL
const tagUrl = (tag: string) => `/${lang}/tags/${encodeURIComponent(tag)}/`;
---

<div class:list={["post-meta flex flex-wrap items-center gap-x-4 gap-y-2 text-xs text-muted", `post-meta--${mode}`]}>
  {/* 作者 - 仅 full 和 article 模式显示 */}
  {(mode === "full" || mode === "article") && showAuthor && (
    <a
      href={`/${lang}/about/`}
      class="meta-link flex items-center gap-1.5 hover:text-accent transition-colors"
    >
      <svg class="size-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2" />
        <circle cx="12" cy="7" r="4" />
      </svg>
      <span>{author}</span>
    </a>
  )}

  {/* 日期 */}
  {dateStr && (
    <time datetime={dateIso} class="flex items-center gap-1.5">
      <svg class="size-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
        <line x1="16" y1="2" x2="16" y2="6" />
        <line x1="8" y1="2" x2="8" y2="6" />
        <line x1="3" y1="10" x2="21" y2="10" />
      </svg>
      <span>{dateStr}</span>
    </time>
  )}

  {/* 阅读时长 */}
  {readingMinutes !== undefined && readingMinutes > 0 && (
    <span class="flex items-center gap-1.5">
      <svg class="size-3.5 opacity-70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10" />
        <polyline points="12 6 12 12 16 14" />
      </svg>
      <span>{readingMinutes} {minutesText}</span>
    </span>
  )}

  {/* 字数 - 仅 article 模式显示 */}
  {mode === "article" && wordCount !== undefined && (
    <span class="flex items-center gap-1.5 opacity-80">
      <span>{wordCount.toLocaleString()} {wordsText}</span>
    </span>
  )}

  {/* 分类 */}
  {category && categoryUrl && (
    <a
      href={categoryUrl}
      class:list={[
        "meta-link transition-colors",
        mode === "article" 
          ? "text-sm font-medium text-accent underline decoration-accent/30 underline-offset-2 hover:decoration-accent"
          : "px-2 py-0.5 rounded-md bg-accent/10 text-accent hover:bg-accent/20"
      ]}
    >
      {category}
    </a>
  )}

  {/* 标签 - full 和 article 模式显示 */}
  {(mode === "full" || mode === "article") && tags.length > 0 && (
    <div class="flex flex-wrap items-center gap-1.5">
      {tags.slice(0, mode === "article" ? undefined : 3).map((tag) => (
        <a
          href={tagUrl(tag)}
          class:list={[
            "meta-link transition-colors",
            mode === "article"
              ? "rounded-md bg-muted/60 px-2.5 py-1 text-xs font-medium text-foreground-soft hover:bg-accent/10 hover:text-accent"
              : "px-2 py-0.5 rounded-md border border-border/50 text-foreground-soft hover:text-accent hover:border-accent/30"
          ]}
        >
          #{tag}
        </a>
      ))}
    </div>
  )}
</div>

<style>
  .meta-link {
    text-decoration: none;
  }

  .meta-link:hover {
    text-decoration: none;
  }

  /* article 模式的分隔符 */
  .post-meta--article > *:not(:last-child)::after {
    content: "";
    margin-left: 1rem;
  }
</style>