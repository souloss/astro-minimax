---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "../../utils/slugify";
import { getLocalizedPostPath } from "../../utils/getPath";
import { getReadingTime } from "../../utils/getReadingTime";
import { getAnimationDelay } from "./PostItemBase.astro";
import dayjs from "dayjs";
import utcPlugin from "dayjs/plugin/utc";
import timezonePlugin from "dayjs/plugin/timezone";
import { SITE } from "virtual:astro-minimax/config";

dayjs.extend(utcPlugin);
dayjs.extend(timezonePlugin);

interface Props {
  post: CollectionEntry<"blog">;
  lang: string;
  index: number;
}

const { post, lang, index } = Astro.props;
const { id, data, body, filePath } = post;
const { title, description, category, tags, pubDatetime, modDatetime, timezone } = data;

const href = getLocalizedPostPath(lang, id, filePath);
const { minutes: readingMinutes } = getReadingTime(body ?? "");
const animationDelay = getAnimationDelay(index);

const isModified = modDatetime && modDatetime > pubDatetime;
const datetime = dayjs(isModified ? modDatetime : pubDatetime).tz(timezone || SITE.timezone);
const dateStr = lang === "zh"
  ? datetime.format("YYYY 年 M 月 D 日")
  : datetime.format("MMM D, YYYY");

const viewTransitionName = slugifyStr(title.replaceAll(".", "-"));
---

<article
  class="group flex items-start gap-4 border-b border-border/40 py-4 transition-colors duration-200 hover:bg-accent/5"
  style={`animation-delay: ${Math.min(index * 60, 400)}ms`}
>
  <!-- Left: Date + Category (fixed width) -->
  <div class="shrink-0 w-24 text-right">
    <time class="text-xs font-medium text-muted" datetime={datetime.toISOString()}>
      {dateStr}
    </time>
    {category && (
      <div class="mt-1 text-xs text-accent">
        {category}
      </div>
    )}
  </div>

  <!-- Right: Title + Summary + Metadata -->
  <div class="min-w-0 flex-1">
    <a href={href} class="block decoration-accent/30 group-hover:underline">
      <h3 class="text-base font-semibold leading-snug text-foreground">
        {title}
      </h3>
    </a>
    <p class="mt-1 line-clamp-2 text-sm text-foreground-soft">
      {description}
    </p>
    <div class="mt-2 flex items-center gap-3 text-xs text-muted">
      <span>{readingMinutes} min</span>
      {tags && tags.length > 0 && (
        <div class="flex gap-1.5">
          {tags.slice(0, 2).map((tag) => (
            <span class="text-accent/80">#{tag}</span>
          ))}
        </div>
      )}
    </div>
  </div>
</article>