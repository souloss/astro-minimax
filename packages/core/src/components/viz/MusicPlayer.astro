---
/**
 * APlayer 音乐播放器组件
 * 使用 MetingJS 支持网易云、QQ 音乐、酷狗等平台
 *
 * 使用方式：
 * <MusicPlayer id="歌曲/歌单ID" type="song" server="netease" />
 *
 * 参数：
 * - id: 歌曲/歌单/专辑 ID（必填）
 * - server: 平台 - netease/tencent/kugou（默认 netease）
 * - type: 类型 - song/playlist/album/search/artist（默认 song）
 * - autoplay: 自动播放（默认 false）
 * - theme: 播放器主题色（默认使用站点 accent 颜色）
 */

interface Props {
  id: string;
  server?: "netease" | "tencent" | "kugou";
  type?: "song" | "playlist" | "album" | "search" | "artist";
  autoplay?: boolean;
  theme?: string;
}

const {
  id,
  server = "netease",
  type = "song",
  autoplay = false,
  // Default to accent color - will be set dynamically via JS
  theme = "var(--accent)",
} = Astro.props;
---

<div class="music-player-wrapper my-6 min-h-[140px]">
  <div
    class="music-player-loading text-muted-foreground flex items-center justify-center gap-2 py-8"
    data-loading
  >
    <svg class="size-6 animate-spin" viewBox="0 0 24 24" aria-hidden="true">
      <circle
        class="opacity-25"
        cx="12"
        cy="12"
        r="10"
        stroke="currentColor"
        stroke-width="4"
        fill="none"></circle>
      <path
        class="opacity-75"
        fill="currentColor"
        d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
      ></path>
    </svg>
    <span class="text-sm">加载播放器...</span>
  </div>
  <meting-js
    id={id}
    server={server}
    type={type}
    auto={autoplay ? "true" : "false"}
    theme={theme}
    fixed="false"
    mini="false"
    list-folded="true"
    order="list"
    preload="auto"
    mutex="true"></meting-js>
</div>

<script>
  function loadResources() {
    if (document.querySelector('link[href*="APlayer.min.css"]')) {
      return Promise.resolve();
    }

    return new Promise<void>(resolve => {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = "https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.css";
      document.head.appendChild(link);

      const aplayerScript = document.createElement("script");
      aplayerScript.src =
        "https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.js";
      aplayerScript.onload = () => {
        const metingScript = document.createElement("script");
        metingScript.src =
          "https://cdn.jsdelivr.net/npm/meting@2/dist/Meting.min.js";
        metingScript.onload = () => {
          const hideLoading = () => {
            document
              .querySelectorAll(".music-player-wrapper [data-loading]")
              .forEach(el => el.classList.add("hidden"));
          };
          setTimeout(hideLoading, 500);
          if (document.querySelector(".aplayer")) hideLoading();
          resolve(void 0);
        };
        document.head.appendChild(metingScript);
      };
      document.head.appendChild(aplayerScript);
    });
  }

  loadResources();
  document.addEventListener("astro:page-load", loadResources);
</script>

<style is:global>
  .music-player-wrapper {
    border-radius: 0.5rem;
    overflow: hidden;
    margin: 1.5rem 0;
  }

  /* APlayer 样式优化 */
  .aplayer {
    margin: 0 !important;
    font-family: inherit !important;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.1);
  }

  .aplayer .aplayer-lrc::before,
  .aplayer .aplayer-lrc::after {
    background: transparent !important;
  }

  /* 暗色主题适配 */
  html[data-theme="dark"] .aplayer {
    color: var(--foreground-soft);
  }

  html[data-theme="dark"] .aplayer .aplayer-body {
    background-color: var(--surface);
  }

  html[data-theme="dark"] .aplayer .aplayer-info {
    background-color: var(--surface);
    border-color: var(--border);
  }

  html[data-theme="dark"] .aplayer .aplayer-pic {
    background-color: var(--card);
  }

  html[data-theme="dark"] .aplayer .aplayer-list {
    background-color: var(--surface);
  }

  html[data-theme="dark"] .aplayer .aplayer-list li {
    border-color: var(--border);
    color: var(--foreground-soft);
  }

  html[data-theme="dark"] .aplayer .aplayer-list li:hover {
    background: var(--muted);
  }

  html[data-theme="dark"] .aplayer .aplayer-list li.aplayer-list-light {
    background: var(--card);
  }

  html[data-theme="dark"] .aplayer .aplayer-miniswitcher {
    background: var(--card);
  }

  html[data-theme="dark"] .aplayer .aplayer-controller {
    background-color: var(--surface);
  }
</style>
