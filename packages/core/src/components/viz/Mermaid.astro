---
import { randomUUID } from "node:crypto";
import VizContainer from "./VizContainer.astro";

interface Props {
  code: string;
}

const { code } = Astro.props;
const uniqueId = `mermaid-${randomUUID()}`;
---

<VizContainer minHeight="120px">
  <div class="mermaid-wrapper" data-mermaid-id={uniqueId} data-viz-type="mermaid">
    <div class="mermaid-output" id={`${uniqueId}-output`}>
      <div class="mermaid-placeholder">
        <svg class="size-8 animate-pulse text-foreground-soft/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 3h18v18H3z" stroke-dasharray="4 2" /><path d="M9 3v18M15 3v18M3 9h18M3 15h18" stroke-dasharray="2 2" opacity="0.5" />
        </svg>
      </div>
    </div>
    <script
      is:inline
      type="application/json"
      class="mermaid-code"
      set:html={JSON.stringify(code)}
    />
  </div>
</VizContainer>

<script>
  import mermaid from "mermaid";

  function getIsDark(): boolean {
    return document.documentElement.getAttribute("data-theme") === "dark";
  }

  function getMermaidConfig(isDark: boolean) {
    const base = {
      fontSize: "14px",
      fontFamily: '"Inter", "Segoe UI", system-ui, sans-serif',
    };

    if (isDark) {
      return {
        ...base,
        primaryColor: "#1e293b",
        primaryTextColor: "#f8fafc",
        primaryBorderColor: "#6366f1",
        lineColor: "#94a3b8",
        background: "transparent",
        nodeBkg: "#1e293b",
        nodeBorder: "#6366f1",
        nodeTextColor: "#f8fafc",
        clusterBkg: "#1e293b",
        clusterBorder: "#6366f1",
        edgeLabelBackground: "#1e293b",
        actorBorder: "#6366f1",
        actorBkg: "#1e293b",
        actorTextColor: "#f8fafc",
        actorLineColor: "#94a3b8",
        signalColor: "#94a3b8",
        signalTextColor: "#f8fafc",
        sequenceNumberColor: "#f8fafc",
        noteBkg: "#1e293b",
        noteBorder: "#6366f1",
        noteTextColor: "#f8fafc",
      };
    }

    return {
      ...base,
      primaryColor: "#eff6ff",
      primaryTextColor: "#1f2937",
      primaryBorderColor: "#3b82f6",
      lineColor: "#374151",
      background: "#ffffff",
      nodeBkg: "#eff6ff",
      nodeBorder: "#3b82f6",
      nodeTextColor: "#1f2937",
      clusterBkg: "#eff6ff",
      clusterBorder: "#3b82f6",
      edgeLabelBackground: "#ffffff",
      actorBorder: "#3b82f6",
      actorBkg: "#f0f9ff",
      actorTextColor: "#1f2937",
      actorLineColor: "#374151",
      signalColor: "#374151",
      signalTextColor: "#1f2937",
      sequenceNumberColor: "#1f2937",
      noteBkg: "#f0f9ff",
      noteBorder: "#3b82f6",
      noteTextColor: "#1f2937",
    };
  }

  let renderCounter = 0;
  let isInitialized = false;
  let currentTheme: boolean | null = null;

  function initMermaid(isDark: boolean) {
    if (isInitialized && currentTheme === isDark) return;
    isInitialized = true;
    currentTheme = isDark;
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: "loose",
      theme: "base" as const,
      themeVariables: getMermaidConfig(isDark),
    });
  }

  async function renderDiagram(wrapper: HTMLElement, isDark: boolean) {
    const id = wrapper.getAttribute("data-mermaid-id");
    const codeScript = wrapper.querySelector("script.mermaid-code");
    const output = wrapper.querySelector<HTMLElement>(`#${id}-output`);

    if (!output || !codeScript) return;

    const code = JSON.parse(codeScript.textContent || '""');
    if (!code) return;

    try {
      renderCounter++;
      const svgId = `${id}-svg-${renderCounter}`;
      const { svg } = await mermaid.render(svgId, code);
      output.innerHTML = svg;
    } catch (error) {
      output.innerHTML = `<p class="mermaid-error">Render error: ${error instanceof Error ? error.message : "unknown"}</p>`;
    }
  }

  async function renderPreBlock(pre: HTMLElement, isDark: boolean) {
    const code = pre.textContent || "";
    const uniqueId = `mermaid-pre-${Math.random().toString(36).slice(2, 11)}`;

    const wrapper = document.createElement("div");
    wrapper.className = "mermaid-wrapper";
    wrapper.setAttribute("data-mermaid-id", uniqueId);
    wrapper.setAttribute("data-viz-type", "mermaid");

    const output = document.createElement("div");
    output.className = "mermaid-output";
    output.id = `${uniqueId}-output`;

    const codeScript = document.createElement("script");
    codeScript.type = "application/json";
    codeScript.className = "mermaid-code";
    codeScript.textContent = JSON.stringify(code);

    wrapper.appendChild(output);
    wrapper.appendChild(codeScript);
    pre.parentNode?.replaceChild(wrapper, pre);

    try {
      renderCounter++;
      const svgId = `${uniqueId}-svg-${renderCounter}`;
      const { svg } = await mermaid.render(svgId, code);
      output.innerHTML = svg;
    } catch (error) {
      output.innerHTML = `<p class="mermaid-error">Render error: ${error instanceof Error ? error.message : "unknown"}</p>`;
    }
  }

  async function renderAllVisible() {
    const isDark = getIsDark();
    initMermaid(isDark);

    const observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          const el = entry.target as HTMLElement;
          obs.unobserve(el);

          if (el.matches("pre.mermaid")) {
            renderPreBlock(el, isDark);
          } else if (el.matches(".mermaid-wrapper")) {
            renderDiagram(el, isDark);
          }
        }
      },
      { rootMargin: "200px" }
    );

    document.querySelectorAll<HTMLElement>(".mermaid-wrapper").forEach(wrapper => {
      const output = wrapper.querySelector(".mermaid-output");
      const hasContent = output && output.querySelector("svg");
      if (!hasContent) observer.observe(wrapper);
    });

    document.querySelectorAll<HTMLElement>("pre.mermaid").forEach(pre => {
      observer.observe(pre);
    });
  }

  async function reRenderAll() {
    const isDark = getIsDark();
    initMermaid(isDark);

    const wrappers = document.querySelectorAll<HTMLElement>(".mermaid-wrapper");
    for (const wrapper of wrappers) {
      await renderDiagram(wrapper, isDark);
    }
  }

  window.addEventListener("themechange", () => {
    if ("requestIdleCallback" in window) {
      requestIdleCallback(() => reRenderAll(), { timeout: 300 });
    } else {
      setTimeout(() => reRenderAll(), 100);
    }
  });

  function init() {
    renderAllVisible();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", init);
  } else {
    init();
  }

  document.addEventListener("astro:page-load", init);
</script>

<style>
  .mermaid-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
    padding: 1rem;
  }

  .mermaid-output {
    width: 100%;
    overflow-x: auto;
    display: flex;
    justify-content: center;
  }

  .mermaid-output :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .mermaid-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 80px;
    width: 100%;
  }

  .mermaid-error {
    color: #ef4444;
    text-align: center;
    padding: 1rem;
  }

  :global(html[data-theme="dark"]) .mermaid-error {
    color: #f87171;
  }
</style>
