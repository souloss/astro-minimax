---
import VizContainer from "./VizContainer.astro";

interface Props {
  src: string;
  cols?: number;
  rows?: number;
  speed?: number;
  idleTimeLimit?: number;
  poster?: string;
  fit?: "width" | "height" | "both" | "none";
  autoPlay?: boolean;
  loop?: boolean;
  preload?: boolean;
}

const {
  src,
  cols = 80,
  rows = 24,
  speed = 1,
  idleTimeLimit = 2,
  poster,
  fit = "width",
  autoPlay = false,
  loop = false,
  preload = true,
} = Astro.props;
---

<VizContainer minHeight="200px" enableZoom={false}>
  <div
    class="asciinema-wrapper"
    data-src={src}
    data-cols={cols}
    data-rows={rows}
    data-speed={speed}
    data-idle-time-limit={idleTimeLimit}
    data-fit={fit}
    data-auto-play={autoPlay}
    data-loop={loop}
    data-preload={preload}
    data-poster={poster ?? ""}
  >
    <div class="asciinema-placeholder">
      <svg class="size-8 animate-pulse text-foreground-soft/40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <rect x="2" y="4" width="20" height="16" rx="2" />
        <path d="M7 15l3-3-3-3" /><line x1="13" y1="15" x2="17" y2="15" />
      </svg>
    </div>
  </div>
</VizContainer>

<script>
  const CDN_BASE = "https://cdn.jsdelivr.net/npm/asciinema-player@3.8.2/dist/bundle";

  let cssLoaded = false;
  let jsLoaded = false;

  function loadCSS(): Promise<void> {
    if (cssLoaded) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const link = document.createElement("link");
      link.rel = "stylesheet";
      link.href = `${CDN_BASE}/asciinema-player.css`;
      link.onload = () => {
        cssLoaded = true;
        resolve();
      };
      link.onerror = reject;
      document.head.appendChild(link);
    });
  }

  function loadJS(): Promise<void> {
    if (jsLoaded) return Promise.resolve();
    return new Promise((resolve, reject) => {
      const script = document.createElement("script");
      script.src = `${CDN_BASE}/asciinema-player.min.js`;
      script.onload = () => {
        jsLoaded = true;
        resolve();
      };
      script.onerror = reject;
      document.head.appendChild(script);
    });
  }

  interface AsciinemaPlayerAPI {
    create: (
      src: string,
      container: HTMLElement,
      opts: Record<string, unknown>
    ) => { dispose: () => void };
  }

  let observer: IntersectionObserver | null = null;

  function ensureObserver(): IntersectionObserver {
    if (observer) return observer;

    observer = new IntersectionObserver(
      (entries, obs) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;

          const el = entry.target as HTMLElement;
          // Check if already initialized (prevents double render)
          if (el.dataset.asciinemaInit) continue;

          // Mark as initializing immediately to prevent race conditions
          el.dataset.asciinemaInit = "true";
          obs.unobserve(el);

          renderPlayer(el);
        }
      },
      { rootMargin: "200px" }
    );

    return observer;
  }

  async function renderPlayer(wrapper: HTMLElement) {
    await Promise.all([loadCSS(), loadJS()]);

    const AsciinemaPlayer = (window as unknown as Record<string, unknown>)
      .AsciinemaPlayer as AsciinemaPlayerAPI | undefined;
    if (!AsciinemaPlayer) return;

    const placeholder = wrapper.querySelector(".asciinema-placeholder");
    if (placeholder) placeholder.remove();

    AsciinemaPlayer.create(wrapper.dataset.src || "", wrapper, {
      cols: Number(wrapper.dataset.cols) || 80,
      rows: Number(wrapper.dataset.rows) || 24,
      speed: Number(wrapper.dataset.speed) || 1,
      idleTimeLimit: Number(wrapper.dataset.idleTimeLimit) || 2,
      theme: "minimax",
      fit: wrapper.dataset.fit || "width",
      autoPlay: wrapper.dataset.autoPlay === "true",
      loop: wrapper.dataset.loop === "true",
      preload: wrapper.dataset.preload !== "false",
      poster: wrapper.dataset.poster || undefined,
    });
  }

  function initAsciinemaPlayers() {
    const obs = ensureObserver();

    // Only observe elements that haven't been initialized
    document
      .querySelectorAll<HTMLElement>(
        ".asciinema-wrapper:not([data-asciinema-init])"
      )
      .forEach((wrapper) => {
        obs.observe(wrapper);
      });
  }

  // Handle both initial load and View Transitions navigation
  document.addEventListener("astro:page-load", initAsciinemaPlayers);

  // Fallback for first load when View Transitions might not have fired yet
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAsciinemaPlayers);
  } else {
    initAsciinemaPlayers();
  }
</script>

<style is:global>
  .asciinema-wrapper {
    width: 100%;
    min-height: 200px;
  }

  .asciinema-placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 200px;
    width: 100%;
  }

  .asciinema-wrapper .ap-wrapper {
    border-radius: 0.5rem;
    overflow: hidden;
  }

  /* Custom asciinema theme that switches via CSS with data-theme */
  .asciinema-player-theme-minimax {
    --term-color-foreground: #374151;
    --term-color-background: #f9fafb;
    --term-color-0: #1f2937;
    --term-color-1: #dc2626;
    --term-color-2: #16a34a;
    --term-color-3: #ca8a04;
    --term-color-4: #2563eb;
    --term-color-5: #9333ea;
    --term-color-6: #0891b2;
    --term-color-7: #e5e7eb;
    --term-color-8: #6b7280;
    --term-color-9: #ef4444;
    --term-color-10: #22c55e;
    --term-color-11: #eab308;
    --term-color-12: #3b82f6;
    --term-color-13: #a855f7;
    --term-color-14: #06b6d4;
    --term-color-15: #f9fafb;
    transition: --term-color-foreground 0.2s, --term-color-background 0.2s;
  }

  html[data-theme="dark"] .asciinema-player-theme-minimax {
    --term-color-foreground: #e5e7eb;
    --term-color-background: #1e293b;
    --term-color-0: #334155;
    --term-color-1: #f87171;
    --term-color-2: #4ade80;
    --term-color-3: #facc15;
    --term-color-4: #60a5fa;
    --term-color-5: #c084fc;
    --term-color-6: #22d3ee;
    --term-color-7: #f1f5f9;
    --term-color-8: #94a3b8;
    --term-color-9: #fca5a5;
    --term-color-10: #86efac;
    --term-color-11: #fde047;
    --term-color-12: #93c5fd;
    --term-color-13: #d8b4fe;
    --term-color-14: #67e8f9;
    --term-color-15: #f8fafc;
  }
</style>