---
/**
 * BackToTopButton - 返回顶部按钮组件
 * 使用 Tailwind CSS 重构，统一设计系统
 */
import IconArrowNarrowUp from "../../assets/icons/IconArrowNarrowUp.svg";
---

<!-- 返回顶部按钮 - 仅桌面端显示 -->
<div class="pointer-events-none absolute right-0 top-0 size-12 overflow-visible z-[999] hidden lg:block">
  <button
    id="back-to-top-btn"
    aria-label="Back to Top"
    class="back-to-top-btn group
           pointer-events-auto fixed z-[1000]
           flex items-center justify-center
           size-12 rounded-full
           bg-card border border-border
           text-foreground-soft
           shadow-lg shadow-shadow-elevated/20
           cursor-pointer
           opacity-0 scale-90 pointer-events-none
           transition-all duration-300 ease-out
           hover:scale-105 hover:bg-card-hover hover:shadow-xl hover:border-accent/30
           active:scale-95
           focus-visible:outline-2 focus-visible:outline-dashed focus-visible:outline-accent
           dark:bg-surface dark:hover:bg-card-hover"
  >
    <IconArrowNarrowUp class="size-5 transition-transform duration-200 group-hover:-translate-y-0.5" />
  </button>
</div>

<style>
  /* 显示状态 - 由 JS 控制 */
  .back-to-top-btn.show {
    @apply opacity-100 scale-100 pointer-events-auto;
  }

  /* 高对比度模式支持 */
  @media (forced-colors: active) {
    .back-to-top-btn {
      @apply border-2 border-current;
    }
  }
</style>

<script is:raw is:inline>
  window.backToTop = function () {
    window.scroll({ top: 0, behavior: "smooth" });
  };

  // 返回顶部按钮管理器
  if (typeof window.BackToTopManager === "undefined") {
    window.BackToTopManager = class BackToTopManager {
      constructor() {
        this.button = document.getElementById("back-to-top-btn");
        this.init();
      }

      init() {
        if (!this.button) return;
        this.setupScrollListener();
      }

      setupScrollListener() {
        const updateVisibility = () => {
          const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
          // 当滚动超过200px时显示按钮
          if (scrollTop > 200) {
            this.button.classList.add("show");
          } else {
            this.button.classList.remove("show");
          }
        };

        window.addEventListener("scroll", updateVisibility, { passive: true });
        // 初始检查
        updateVisibility();
      }
    };
  }

  // 页面加载完成后初始化
  function initBackToTop() {
    new window.BackToTopManager();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBackToTop);
  } else {
    initBackToTop();
  }

  // Astro View Transitions 支持
  document.addEventListener("astro:after-swap", initBackToTop);
</script>