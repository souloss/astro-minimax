---
import IconX from "../../assets/icons/IconX.svg";
import IconHome from "../../assets/icons/IconHome.svg";
import IconArticle from "../../assets/icons/IconArticle.svg";
import IconTag from "../../assets/icons/IconTag.svg";
import IconUser from "../../assets/icons/IconUser.svg";
import IconSearch from "../../assets/icons/IconSearch.svg";
import IconArchive from "../../assets/icons/IconArchive.svg";
import IconSeries from "../../assets/icons/IconSeries.svg";
import IconProject from "../../assets/icons/IconProject.svg";
import IconMenuDeep from "../../assets/icons/IconMenuDeep.svg";
import { SITE } from "virtual:astro-minimax/config";
import { t, type TranslationKey } from "../../utils/i18n";
import { isPathActive } from "../../utils/pathUtils";
import DocSearch from "../search/DocSearch.astro";

const useDocSearch = SITE.search?.provider === 'docsearch' && SITE.search?.docsearch;
const dsConfig = SITE.search?.docsearch;

const { pathname } = Astro.url;
const isActive = (path: string) => isPathActive(path, pathname);

const { lang = "zh" } = Astro.props;

const base = `/${lang}`;

const iconMap: Record<string, typeof IconHome> = {
  home: IconHome,
  posts: IconArticle,
  tags: IconTag,
  categories: IconTag,
  series: IconSeries,
  projects: IconProject,
  about: IconUser,
  friends: IconUser,
  archives: IconArchive,
};

const hrefMap: Record<string, string> = {
  home: `${base}/`,
  posts: `${base}/posts`,
  tags: `${base}/tags`,
  categories: `${base}/categories`,
  series: `${base}/series`,
  projects: `${base}/projects`,
  about: `${base}/about`,
  friends: `${base}/friends`,
  archives: `${base}/archives`,
  search: `${base}/search`,
};

const navItems = (SITE.nav?.items ?? [])
  .filter(i => i.enabled)
  .map(i => ({
    href: hrefMap[i.key] ?? `${base}/${i.key}`,
    label: t(`nav.${i.key}` as TranslationKey, lang),
    icon: iconMap[i.key] ?? IconArticle,
  }));
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-xl bg-accent px-4 py-2 text-sm font-medium text-white 
         backdrop-blur-lg transition-all duration-300 focus:top-4 focus:shadow-lg focus:shadow-accent/25"
>
  Skip to content
</a>

<header
  id="main-header"
  data-nav-overflow="false"
  class="fixed top-0 left-0 right-0 z-40 w-full
         border-b border-border/50 bg-surface/70 backdrop-blur-xl
         transition-all duration-300 ease-out
         supports-[backdrop-filter]:bg-surface/60"
>
  <div
    class="mx-auto flex h-14 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8"
  >
    <a
      href={`/${lang}/`}
      class="text-lg font-bold tracking-tight text-foreground 
             transition-all duration-200 
             hover:text-accent hover:tracking-normal
             sm:text-xl"
    >
      <span class="text-gradient">{SITE.title}</span>
    </a>

    <nav id="nav-menu" class="flex items-center">
      {/* Desktop: Icon-only on sm, full on lg+ */}
      <ul id="desktop-nav" class="hidden items-center gap-0.5 sm:flex lg:gap-1">
        {
          navItems.map(({ href, label, icon: Icon }) => (
            <li>
              <a
                href={href}
                title={label}
                class:list={[
                  // Base styles
                  "flex items-center rounded-xl py-2 transition-all duration-200 ease-out",
                  // Icon-only on sm, with text on lg+
                  "px-2.5 lg:px-3.5 lg:gap-2",
                  // Colors
                  "text-foreground-soft hover:bg-accent/10 hover:text-accent",
                  // Active state
                  { "bg-accent/15 text-accent font-semibold": isActive(href) },
                ]}
              >
                <Icon class="size-4 shrink-0 opacity-80" />
                <span class="hidden text-sm font-medium lg:inline">{label}</span>
              </a>
            </li>
          ))
        }
        {/* Language & Search - always visible */}
        <li class="ml-1 flex items-center gap-0.5 border-l border-border/60 pl-2 lg:ml-2 lg:gap-1 lg:pl-3">
          <button
            id="lang-switch-btn"
            class="rounded-xl px-2 py-2 text-xs font-bold tracking-wide
                   text-muted transition-all duration-200 
                   hover:bg-accent/10 hover:text-accent"
            title="Switch language"
            aria-label="Switch language"
          >
            <span id="lang-label">EN</span>
          </button>
          {useDocSearch && dsConfig ? (
            <DocSearch
              appId={dsConfig.appId}
              apiKey={dsConfig.apiKey}
              indexName={dsConfig.indexName}
              placeholder={dsConfig.placeholder}
              lang={lang}
            />
          ) : (
            <a
              href={`/${lang}/search`}
              class:list={[
                "rounded-xl p-2 transition-all duration-200 ease-out",
                "text-foreground-soft hover:bg-accent/10 hover:text-accent",
                { "bg-accent/15 text-accent": isActive(`/${lang}/search`) },
              ]}
              title={t("nav.search", lang)}
              aria-label={t("nav.search", lang)}
            >
              <IconSearch class="size-4" />
            </a>
          )}
        </li>
      </ul>

<button
  id="menu-btn"
  class="rounded-xl p-2.5 transition-all duration-200 
         hover:bg-accent/10 hover:text-accent sm:hidden"
  aria-label="Open Menu"
  aria-expanded="false"
  aria-controls="mobile-menu"
>
        <IconX id="close-icon" class="hidden size-5" />
        <IconMenuDeep id="menu-icon" class="size-5" />
      </button>
    </nav>
  </div>

  <div
    id="mobile-menu"
    class="hidden border-t border-border/50 bg-surface/95 backdrop-blur-xl"
  >
    <ul class="flex flex-col gap-1 p-4">
      {
        navItems.map(({ href, label, icon: Icon }) => (
          <li>
            <a
              href={href}
              class:list={[
                "flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium",
                "transition-all duration-200 ease-out",
                "text-foreground-soft hover:bg-accent/10 hover:text-accent",
                { "bg-accent/15 text-accent font-semibold": isActive(href) },
              ]}
            >
              <Icon class="size-5 opacity-80" />
              <span>{label}</span>
            </a>
          </li>
        ))
      }
      <li class="mt-2 border-t border-border/50 pt-3">
        <a
          href={`/${lang}/search`}
          class:list={[
            "flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium",
            "transition-all duration-200 ease-out",
            "text-foreground-soft hover:bg-accent/10 hover:text-accent",
            { "bg-accent/15 text-accent": isActive(`/${lang}/search`) },
          ]}
        >
          <IconSearch class="size-5" />
          <span>{t("nav.search", lang)}</span>
        </a>
      </li>
      <li>
        <button
          id="lang-switch-btn-mobile"
          class="flex w-full items-center gap-3 rounded-xl px-4 py-3 text-sm font-medium
                 text-foreground-soft transition-all duration-200 
                 hover:bg-accent/10 hover:text-accent"
          aria-label="Switch language"
        >
          <svg
            class="size-5 opacity-80"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <path d="M2 12h20"></path>
            <path
              d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
            ></path>
          </svg>
          <span id="lang-label-mobile">English</span>
        </button>
      </li>
    </ul>
  </div>
</header>

<div class="h-14"></div>

<script>
  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const mobileMenu = document.querySelector("#mobile-menu");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !mobileMenu || !menuIcon || !closeIcon) return;

    menuBtn.addEventListener("click", () => {
      const openMenu = menuBtn.getAttribute("aria-expanded") === "true";

      menuBtn.setAttribute("aria-expanded", openMenu ? "false" : "true");
      menuBtn.setAttribute("aria-label", openMenu ? "Open Menu" : "Close Menu");

      mobileMenu.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
    });
  }

  toggleNav();
  document.addEventListener("astro:after-swap", toggleNav);

  // Overflow detection for responsive nav
  function checkNavOverflow() {
    const header = document.getElementById("main-header");
    const desktopNav = document.getElementById("desktop-nav");
    const menuBtn = document.getElementById("menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");

    if (!header || !desktopNav || !menuBtn || !mobileMenu) return;

    // Get header inner container
    const container = header.querySelector(".mx-auto") as HTMLElement | null;
    if (!container) return;

    // Get logo link
    const logo = container.querySelector("a[href]") as HTMLElement | null;
    if (!logo) return;

    // Calculate available space for nav
    const containerWidth = container.offsetWidth;
    const logoWidth = logo.offsetWidth;

    // Check if nav items overflow the available space
    // Add some buffer (20px) for gap/padding
    const availableWidth = containerWidth - logoWidth - 20;
    const navWidth = desktopNav.scrollWidth;

    const isOverflow = navWidth > availableWidth;

    // Update header state
    header.setAttribute("data-nav-overflow", isOverflow ? "true" : "false");

    // Toggle visibility based on overflow
    if (isOverflow) {
      // Hide desktop nav, show hamburger
      desktopNav.classList.remove("sm:flex");
      desktopNav.classList.add("sm:hidden");
      menuBtn.classList.remove("sm:hidden");
      menuBtn.classList.add("sm:flex");
    } else {
      // Show desktop nav, hide hamburger
      desktopNav.classList.remove("sm:hidden");
      desktopNav.classList.add("sm:flex");
      menuBtn.classList.remove("sm:flex");
      menuBtn.classList.add("sm:hidden");
      // Close mobile menu if open (when switching back to desktop nav)
      if (!mobileMenu.classList.contains("hidden")) {
        mobileMenu.classList.add("hidden");
        menuBtn.setAttribute("aria-expanded", "false");
        menuBtn.setAttribute("aria-label", "Open Menu");
        const menuIcon = document.getElementById("menu-icon");
        const closeIcon = document.getElementById("close-icon");
        menuIcon?.classList.remove("hidden");
        closeIcon?.classList.add("hidden");
      }
    }
  }

  // Initial check
  checkNavOverflow();

  // Re-check on resize
  const resizeObserver = new ResizeObserver(() => {
    checkNavOverflow();
  });

  const header = document.getElementById("main-header");
  if (header) {
    resizeObserver.observe(header);
  }

  // Re-init on Astro page transitions
  document.addEventListener("astro:after-swap", () => {
    checkNavOverflow();
    const newHeader = document.getElementById("main-header");
    if (newHeader) {
      resizeObserver.observe(newHeader);
    }
  });

  function initLangSwitcher() {
    const btns = [
      document.getElementById("lang-switch-btn"),
      document.getElementById("lang-switch-btn-mobile"),
    ];
    const label = document.getElementById("lang-label");
    const labelMobile = document.getElementById("lang-label-mobile");

    const path = window.location.pathname;
    const isZh = path.startsWith("/zh/") || path === "/zh";

    if (label) label.textContent = isZh ? "EN" : "中";
    if (labelMobile) labelMobile.textContent = isZh ? "English" : "中文";

    btns.forEach(btn => {
      btn?.addEventListener("click", () => {
        if (isZh) {
          const newPath = path.replace(/^\/zh\/?/, "/en/") || "/en/";
          window.location.href = newPath;
        } else {
          const newPath = path.replace(/^\/en\/?/, "/zh/") || "/zh/";
          window.location.href = newPath;
        }
      });
    });
  }

  initLangSwitcher();
  document.addEventListener("astro:after-swap", initLangSwitcher);
</script>