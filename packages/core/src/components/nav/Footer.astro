---
import type { HTMLAttributes } from "astro/types";
import { SITE } from "virtual:astro-minimax/config";
import { t } from "../../utils/i18n";

const currentYear = new Date().getFullYear();

const startDateStr = SITE.startDate;
const runningDays = startDateStr
  ? Math.floor((Date.now() - new Date(startDateStr).getTime()) / (1000 * 60 * 60 * 24))
  : 0;

type Props = {
  noMarginTop?: boolean;
  lang?: string;
} & HTMLAttributes<"footer">;

const {
  noMarginTop = false,
  lang = "zh",
  class: className,
  ...attrs
} = Astro.props;

const copyrightText = t("footer.copyright", lang)
  .replace("{year}", String(currentYear))
  .replace("{author}", SITE.author);
---

<footer
  class:list={[
    "app-layout max-w-5xl",
    { "mt-auto": !noMarginTop },
    className
  ]}
  {...attrs}
>
  <div
    class:list={[
      "py-8 sm:py-6",
      "border-t border-border/50",
      "flex flex-col items-center justify-center",
    ]}
  >
    <div
      class="flex flex-col items-center justify-center gap-2 text-sm whitespace-nowrap 
             text-foreground-soft sm:flex-row sm:gap-0"
    >
      <div class="flex items-center gap-3 rounded-full border border-border/50 
                  bg-surface/60 px-5 py-2.5 backdrop-blur-sm
                  transition-all duration-300 hover:border-accent/30 hover:bg-surface/80">
        <a
          href={`/${lang}/`}
          class="flex items-center gap-2.5 transition-all duration-200 hover:text-accent"
        >
          <img
            src="/favicon.ico"
            alt={`${SITE.author}'s avatar`}
            class="size-5 rounded-full ring-2 ring-accent/20"
          />
          <span class="font-medium">{t("footer.hi", lang)}, {SITE.author}</span>
        </a>
      </div>

      <span class="hidden px-3 text-border-strong sm:inline">|</span>

      <div class="flex items-center gap-4 text-muted">
        <span class="flex items-center gap-1.5">
          <svg class="size-4 text-accent/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14"></path>
            <path d="M12 5v14"></path>
          </svg>
          {t("footer.running", lang)} {runningDays} {t("footer.days", lang)}
        </span>
        
        <span class="text-border-strong">·</span>
        
        <a
          href="/sitemap-index.xml"
          class="transition-all duration-200 hover:text-accent hover:underline underline-offset-4"
        >
          {t("footer.sitemap", lang)}
        </a>
        
        <span class="text-border-strong">·</span>
        
        <a 
          href="/rss.xml" 
          class="flex items-center gap-1.5 transition-all duration-200 hover:text-accent hover:underline underline-offset-4"
        >
          <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 11a9 9 0 0 1 9 9"></path>
            <path d="M4 4a16 16 0 0 1 16 16"></path>
            <circle cx="5" cy="19" r="1"></circle>
          </svg>
          RSS
        </a>
      </div>
    </div>
    
    <p class="mt-4 text-xs text-muted">
      {copyrightText}
    </p>
  </div>
</footer>