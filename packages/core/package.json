{
  "name": "@astro-minimax/core",
  "version": "0.7.5",
  "type": "module",
  "description": "Core theme package for astro-minimax — layouts, components, styles, utilities and plugins.",
  "author": "Souloss",
  "license": "MIT",
  "keywords": [
    "astro",
    "astro-theme",
    "blog",
    "minimalist",
    "tailwindcss",
    "responsive",
    "seo"
  ],
  "homepage": "https://github.com/souloss/astro-minimax#readme",
  "bugs": {
    "url": "https://github.com/souloss/astro-minimax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/souloss/astro-minimax",
    "directory": "packages/core"
  },
  "exports": {
    ".": "./src/integration.ts",
    "./integration": "./src/integration.ts",
    "./pages/*": "./src/pages/*",
    "./layouts/*.astro": "./src/layouts/*.astro",
    "./components/*": "./src/components/*",
    "./styles/source.css": "./src/styles/source.css",
    "./styles/theme.css": "./src/styles/theme.css",
    "./styles/*.css": "./src/styles/*.css",
    "./assets/icons/*.svg": "./src/assets/icons/*.svg",
    "./utils/*": "./src/utils/*.ts",
    "./plugins/*": "./src/plugins/*.ts",
    "./scripts/*": "./src/scripts/*.ts",
    "./types": "./src/types.ts"
  },
  "files": [
    "src/"
  ],
  "sideEffects": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf node_modules/.cache"
  },
  "peerDependencies": {
    "@astrojs/rss": "^4.0.0",
    "@fontsource/ibm-plex-mono": "^5.0.0",
    "@pagefind/default-ui": "^1.0.0",
    "@resvg/resvg-js": "^2.6.0",
    "@tailwindcss/typography": "^0.5.0",
    "astro": "^5.0.0 || ^6.0.0",
    "dayjs": "^1.11.0",
    "lodash.kebabcase": "^4.1.0",
    "satori": "^0.18.0",
    "slugify": "^1.6.0",
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "astro": "^6.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "@astro-minimax/ai": {
      "optional": true
    },
    "satori": {
      "optional": true
    },
    "@resvg/resvg-js": {
      "optional": true
    },
    "@fontsource/ibm-plex-mono": {
      "optional": true
    },
    "@pagefind/default-ui": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "qrcode": "^1.5.4"
  }
}
