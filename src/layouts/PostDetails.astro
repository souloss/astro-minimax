---
import { render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/nav/Header.astro";
import Footer from "@/components/nav/Footer.astro";
import Tag from "@/components/ui/Tag.astro";
import Datetime from "@/components/ui/Datetime.astro";
import EditPost from "@/components/blog/EditPost.astro";
import ShareLinks from "@/components/blog/ShareLinks.astro";
import BackButton from "@/components/nav/BackButton.astro";
import { getLocalizedPostPath, getPostSlug } from "@/utils/getPath";
import { t } from "@/utils/i18n";
import { slugifyStr } from "@/utils/slugify";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import FloatingTOC from "@/components/blog/FloatingTOC.astro";
import InlineTOC from "@/components/blog/InlineTOC.astro";
import Comments from "@/components/blog/Comments.astro";
import PostActions from "@/components/blog/PostActions.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import { getRelatedPosts } from "@/utils/getRelatedPosts";
import { getReadingTime } from "@/utils/getReadingTime";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  lang?: string;
};

const { post, posts, lang = "zh" } = Astro.props;

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  category,
  series,
  hideEditPost,
} = post.data;

const { Content, headings } = await render(post);
const { minutes: readingMinutes, words: wordCount } = getReadingTime(post.body ?? "");

let ogImageUrl: string | undefined;

// Determine OG image source
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage; // Remote OG image (absolute URL)
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src; // Local asset
}

// Use dynamic OG image if enabled and no remote|local ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  ogImageUrl = `/${lang}/posts/${getPostSlug(post.id)}/index.png`;
}

// Resolve OG image URL (or fallback to SITE.ogImage / default `og.png`)
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  pubDatetime,
  modDatetime,
  canonicalURL,
  ogImage,
  scrollSmooth: true,
  lang,
  tags,
};

const breadcrumbList = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: lang === "zh" ? "首页" : "Home",
      item: `${SITE.website}${lang}/`,
    },
    {
      "@type": "ListItem",
      position: 2,
      name: lang === "zh" ? "文章" : "Posts",
      item: `${SITE.website}${lang}/posts/`,
    },
    ...(category
      ? [
          {
            "@type": "ListItem",
            position: 3,
            name: category,
            item: `${SITE.website}${lang}/categories/${encodeURIComponent(category)}/`,
          },
          {
            "@type": "ListItem",
            position: 4,
            name: title,
          },
        ]
      : [
          {
            "@type": "ListItem",
            position: 3,
            name: title,
          },
        ]),
  ],
};

/* ========== Prev/Next Posts (Series-aware) ========== */

const seriesPosts = series
  ? posts
      .filter(p => p.data.series?.name === series.name)
      .sort((a, b) => (a.data.series?.order ?? 0) - (b.data.series?.order ?? 0))
  : null;

const navList = (seriesPosts ?? posts).map(({ data: { title }, id, filePath }) => ({
  id,
  title,
  filePath,
}));

const currentPostIndex = navList.findIndex(a => a.id === post.id);
const prevPost = currentPostIndex > 0 ? navList[currentPostIndex - 1] : null;
const nextPost = currentPostIndex >= 0 && currentPostIndex < navList.length - 1 ? navList[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <script
    type="application/ld+json"
    is:inline
    set:html={JSON.stringify(breadcrumbList)}
  />
  <Header lang={lang} />
  
  <!-- Sticky Header for Article Reading Progress -->
  <div
    id="sticky-header"
    class="fixed top-0 start-0 z-50 w-full transform border-b border-border bg-background/80 opacity-0 transition-all duration-300 -translate-y-full backdrop-blur-md"
  >
    <div class="app-layout flex h-14 items-center justify-between">
      <div class="flex items-center gap-4 overflow-hidden">
        <span
          class="cursor-pointer truncate text-sm font-medium text-foreground hover:text-accent"
          onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
        >
          {title}
        </span>
      </div>
      <div class="flex items-center gap-2">
        <button
          id="sticky-toc-toggle"
          class="flex items-center gap-1 rounded-md p-2 text-muted-foreground hover:bg-muted/50 hover:text-accent sm:hidden"
          aria-label="Toggle Table of Contents"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="8" y1="6" x2="21" y2="6"></line>
            <line x1="8" y1="12" x2="21" y2="12"></line>
            <line x1="8" y1="18" x2="21" y2="18"></line>
            <line x1="3" y1="6" x2="3.01" y2="6"></line>
            <line x1="3" y1="12" x2="3.01" y2="12"></line>
            <line x1="3" y1="18" x2="3.01" y2="18"></line>
          </svg>
        </button>
        <button
          class="rounded-md p-2 text-muted-foreground hover:bg-muted/50 hover:text-accent"
          onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
          aria-label="Scroll to top"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M12 19V5"></path>
            <polyline points="5 12 12 5 19 12"></polyline>
          </svg>
        </button>
      </div>
    </div>
    <div class="absolute bottom-0 start-0 h-[2px] w-full bg-muted/30">
      <div id="progress-bar" class="h-full w-0 bg-accent transition-all duration-150 ease-out"></div>
    </div>
  </div>

  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-accent sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex flex-wrap items-center gap-2">
      {category && (
        <a
          href={`/${lang}/categories/${encodeURIComponent(category)}/`}
          class="text-sm font-medium text-accent hover:underline"
        >
          {category}
        </a>
      )}
      {category && <span class="text-muted-foreground">·</span>}
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" lang={lang} />
      <span class="text-muted-foreground">·</span>
      <span class="text-sm opacity-80 sm:text-base" title={t("post.wordCount", lang).replace("{count}", String(wordCount))}>
        {t("post.readingTime", lang).replace("{min}", String(readingMinutes))}
      </span>
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <InlineTOC headings={headings} />
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>
    <FloatingTOC headings={headings} />

    <hr class="my-8 border-dashed" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={tag} size="sm" lang={lang} />)}
    </ul>

    <ShareLinks />

    <PostActions />

    <hr class="my-6 border-dashed" />

    {series && seriesPosts && seriesPosts.length > 0 && (
      <div class="mb-6 rounded-lg border border-border bg-muted/20 px-4 py-3" data-pagefind-ignore>
        <div class="text-sm font-medium text-muted-foreground">{t("post.series", lang)}：{series.name}</div>
        <ol class="mt-2 list-inside list-decimal space-y-1 text-sm">
          {seriesPosts.map((p) => (
            <li>
              {p.id === post.id ? (
                <span class="font-medium text-accent">{p.data.title}</span>
              ) : (
                <a href={getLocalizedPostPath(lang, p.id)} class="text-foreground/80 hover:text-accent hover:underline">
                  {p.data.title}
                </a>
              )}
            </li>
          ))}
        </ol>
      </div>
    )}

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getLocalizedPostPath(lang, prevPost.id)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>{t("post.prev", lang)}</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getLocalizedPostPath(lang, nextPost.id)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>{t("post.next", lang)}</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>

    <RelatedPosts posts={getRelatedPosts(post, posts)} lang={lang} />

    <Comments />
  </main>
  <Footer lang={lang} />
</Layout>

<script is:inline data-astro-rerun>
  function initStickyHeader() {
    const header = document.getElementById("sticky-header");
    const progressBar = document.getElementById("progress-bar");
    const tocToggle = document.getElementById("sticky-toc-toggle");
    
    if (!header || !progressBar) return;

    // Handle scroll
    document.addEventListener("scroll", () => {
      const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      
      // Update progress bar
      progressBar.style.width = scrolled + "%";
      
      // Show/hide header based on scroll position (e.g. past 300px)
      if (winScroll > 300) {
        header.classList.remove("-translate-y-full", "opacity-0");
      } else {
        header.classList.add("-translate-y-full", "opacity-0");
      }
    });

    // Handle TOC toggle
    if (tocToggle) {
      tocToggle.addEventListener("click", () => {
        // Scroll to InlineTOC and open it
        const inlineToc = document.querySelector("[data-inline-toc]");
        if (inlineToc) {
           inlineToc.scrollIntoView({ behavior: "smooth", block: "center" });
           const toggleBtn = inlineToc.querySelector("[data-toc-toggle]");
           if (toggleBtn && toggleBtn.getAttribute("aria-expanded") === "false") {
             toggleBtn.click();
           }
        }
      });
    }
  }
  initStickyHeader();

  /** Attaches links to headings in the document,
   *  allowing sharing of sections easily */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /* Go to page start after page swap */
  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
