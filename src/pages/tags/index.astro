---
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import TagCloud from "@/components/ui/TagCloud.astro";
import Header from "@/components/nav/Header.astro";
import Footer from "@/components/nav/Footer.astro";
import getTagsWithCount from "@/utils/getTagsWithCount";
import { SITE } from "@/config";

const posts = await getCollection("blog");
const tags = getTagsWithCount(posts);

// Get max and min counts for size calculation
const counts = tags.map(t => t.count);
const maxCount = Math.max(...counts, 1);
const minCount = Math.min(...counts, 0);

// Calculate total posts
const totalPosts = tags.reduce((acc, t) => acc + t.count, 0);
---

<Layout title={`Tags | ${SITE.title}`}>
  <Header />
  <Main pageTitle="Tags" pageDesc="All the tags used in posts.">
    <!-- Stats -->
    <div class="mb-8 flex flex-wrap gap-4 text-sm text-muted-foreground">
      <div class="flex items-center gap-2">
        <span class="font-medium text-foreground">{tags.length}</span>
        <span>tags</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="font-medium text-foreground">{totalPosts}</span>
        <span>tagged posts</span>
      </div>
    </div>
    
    <!-- Tag Cloud -->
    <div class="flex flex-wrap items-center justify-center gap-3 p-6 rounded-lg bg-muted/20 border border-border">
      {tags.map(({ tag, tagName, count }) => (
        <TagCloud
          {tag}
          {tagName}
          {count}
          maxCount={maxCount}
          minCount={minCount}
        />
      ))}
    </div>
    
    <!-- Legend -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-xs text-muted-foreground">
      <span>Size indicates popularity:</span>
      <div class="flex items-center gap-2">
        <span class="text-xs">Less</span>
        <div class="flex items-center gap-1">
          <div class="h-2 w-2 rounded-full bg-foreground/40"></div>
          <div class="h-3 w-3 rounded-full bg-foreground/60"></div>
          <div class="h-4 w-4 rounded-full bg-foreground/80"></div>
          <div class="h-5 w-5 rounded-full bg-foreground"></div>
        </div>
        <span class="text-base font-medium">More</span>
      </div>
    </div>
  </Main>
  <Footer />
</Layout>