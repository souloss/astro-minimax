---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/nav/Header.astro";
import Footer from "@/components/nav/Footer.astro";
import Main from "@/layouts/Main.astro";
import { FRIENDS } from "@/data/friends";
import { SITE } from "@/config";
---

<Layout title={`友链 | ${SITE.title}`}>
  <Header />
  <Main pageTitle="友链" pageDesc="友情链接，欢迎交换">
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {FRIENDS.map((friend) => (
        <a
          href={friend.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex gap-4 rounded-lg border border-border bg-background/50 p-4 transition-colors hover:border-accent hover:bg-muted/30"
        >
          {friend.avatar && (
            <img
              src={friend.avatar}
              alt=""
              class="size-12 shrink-0 rounded-full object-cover"
              width="48"
              height="48"
            />
          )}
          <div class="min-w-0 flex-1">
            <div class="font-semibold text-foreground">{friend.name}</div>
            {friend.description && (
              <div class="mt-1 text-sm text-muted-foreground line-clamp-2">
                {friend.description}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>
  </Main>
  <Footer />
</Layout>
