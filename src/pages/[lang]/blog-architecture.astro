---
import type { GetStaticPaths } from "astro";
import Header from "@/components/nav/Header.astro";
import Footer from "@/components/nav/Footer.astro";
import Layout from "@/layouts/Layout.astro";
import { SITE } from "@/config";
import { layers } from "@/data/blog-architecture";
import type { ArchLayer } from "@/data/blog-architecture";

export const getStaticPaths = (() => [
  { params: { lang: "zh" } },
  { params: { lang: "en" } },
]) satisfies GetStaticPaths;

const { lang } = Astro.params as { lang: "zh" | "en" };
const title = lang === "zh"
  ? "个人技术博客系统架构 2026"
  : "Personal Tech Blog Architecture 2026";
const description = lang === "zh"
  ? "2026 年个人技术博客架构的全面参考文档，涵盖内容模型、创作工具、性能优化、SEO、AI 集成等 10 个核心层次"
  : "Comprehensive architecture reference for personal tech blogs in 2026";

function getItemsCount(layer: ArchLayer): number {
  return layer.sections.reduce((acc, s) => acc + (s.items?.length ?? 0) + (s.table ? s.table.rows.length : 0), 0);
}
---

<Layout lang={lang} title={`${title} | ${SITE.title}`} description={description}>
  <Header lang={lang} />
  <main id="main-content" class="arch-page">
    <!-- Hero Section -->
    <section class="arch-hero">
      <div class="arch-hero-bg"></div>
      <div class="arch-hero-content">
        <div class="arch-hero-badge">SYSTEM ARCHITECTURE REFERENCE · 2026</div>
        <h1 class="arch-hero-title">
          {lang === "zh" ? "个人技术博客系统架构" : "Personal Tech Blog Architecture"}
        </h1>
        <p class="arch-hero-desc">
          {lang === "zh"
            ? "涵盖 10 个核心层次，从内容模型到可持续发展——构建一个现代化个人技术博客所需了解的方方面面"
            : "Covering 10 core layers, from content modeling to sustainability"}
        </p>
        <div class="arch-hero-stats">
          <span><strong>{layers.length}</strong> {lang === "zh" ? "架构层" : "Layers"}</span>
          <span class="arch-hero-dot">·</span>
          <span><strong>{layers.reduce((a, l) => a + l.sections.length, 0)}</strong> {lang === "zh" ? "专题" : "Topics"}</span>
          <span class="arch-hero-dot">·</span>
          <span><strong>{layers.reduce((a, l) => a + getItemsCount(l), 0)}+</strong> {lang === "zh" ? "知识点" : "Items"}</span>
        </div>
      </div>
    </section>

    <!-- View Controls -->
    <nav class="arch-controls">
      <button class="arch-view-btn active" data-view="overview">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>
        {lang === "zh" ? "概览" : "Overview"}
      </button>
      <button class="arch-view-btn" data-view="detail">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="2" y1="4" x2="14" y2="4"/><line x1="2" y1="8" x2="14" y2="8"/><line x1="2" y1="12" x2="10" y2="12"/></svg>
        {lang === "zh" ? "详情" : "Detail"}
      </button>
    </nav>

    <!-- ═══ OVERVIEW LAYER ═══ -->
    <section id="arch-overview" class="arch-overview">
      <div class="arch-overview-grid">
        {layers.map((layer, i) => (
          <button
            class="arch-layer-card"
            data-layer-index={i}
            style={`--lc: ${layer.color}`}
          >
            <div class="arch-lc-header">
              <span class="arch-lc-icon">{layer.icon}</span>
              <span class="arch-lc-code">{layer.code}</span>
              {layer.ai && <span class="arch-ai-tag">AI</span>}
            </div>
            <h3 class="arch-lc-name">{layer.name}</h3>
            <p class="arch-lc-tagline">{layer.tagline}</p>
            <div class="arch-lc-meta">
              <span>{layer.sections.length} {lang === "zh" ? "专题" : "topics"}</span>
              <span>·</span>
              <span>{getItemsCount(layer)} {lang === "zh" ? "知识点" : "items"}</span>
            </div>
            <div class="arch-lc-arrow">→</div>
          </button>
        ))}
      </div>
    </section>

    <!-- ═══ DETAIL LAYER ═══ -->
    <section id="arch-detail" class="arch-detail hidden">
      <!-- Sidebar Nav -->
      <nav class="arch-sidebar">
        <button class="arch-back-btn" data-action="back">
          ← {lang === "zh" ? "返回概览" : "Back"}
        </button>
        <div class="arch-sidebar-list">
          {layers.map((layer, i) => (
            <button
              class="arch-sidebar-item"
              data-nav-index={i}
              style={`--lc: ${layer.color}`}
            >
              <span class="arch-si-icon">{layer.icon}</span>
              <span class="arch-si-code">{layer.code}</span>
              <span class="arch-si-name">{layer.name}</span>
            </button>
          ))}
        </div>
      </nav>

      <!-- Detail Content -->
      <div class="arch-detail-content">
        {layers.map((layer, layerIdx) => (
          <article
            class="arch-layer-detail"
            id={`layer-${layerIdx}`}
            data-layer-idx={layerIdx}
            style={`--lc: ${layer.color}`}
          >
            <header class="arch-ld-header">
              <div class="arch-ld-icon">{layer.icon}</div>
              <div>
                <div class="arch-ld-code">
                  {layer.code}
                  {layer.ai && <span class="arch-ai-tag">AI</span>}
                </div>
                <h2 class="arch-ld-title">{layer.name}</h2>
                <p class="arch-ld-overview">{layer.overview}</p>
              </div>
            </header>

            {layer.sections.map((section) => (
              <div class="arch-section">
                <h3 class="arch-section-title">{section.title}</h3>

                {section.table && (
                  <div class="arch-table-wrap">
                    <table class="arch-table">
                      <thead>
                        <tr>
                          {section.table.headers.map((h) => (
                            <th>{h}</th>
                          ))}
                        </tr>
                      </thead>
                      <tbody>
                        {section.table.rows.map((row) => (
                          <tr>
                            {row.map((cell, ci) => (
                              <td class={ci === 0 ? "arch-td-primary" : ""}>{cell}</td>
                            ))}
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}

                {section.items && (
                  <div class="arch-items-grid">
                    {section.items.map((item) => (
                      <button
                        class="arch-item"
                        data-item-id={item.id}
                        data-has-detail={item.detail ? "true" : "false"}
                      >
                        <div class="arch-item-head">
                          <span class="arch-item-dot"></span>
                          <span class="arch-item-name">
                            {item.name}
                            {item.ai && <span class="arch-ai-tag sm">AI</span>}
                          </span>
                          {item.detail && <span class="arch-item-expand">↗</span>}
                        </div>
                        <p class="arch-item-brief">{item.brief}</p>
                      </button>
                    ))}
                  </div>
                )}

                {section.callout && (
                  <div class="arch-callout">
                    <Fragment set:html={section.callout} />
                  </div>
                )}
              </div>
            ))}
          </article>
        ))}
      </div>
    </section>

    <!-- ═══ MODAL LAYER ═══ -->
    <div id="arch-modal" class="arch-modal hidden" role="dialog" aria-modal="true" aria-label="详细说明">
      <div class="arch-modal-backdrop"></div>
      <div class="arch-modal-container">
        <div class="arch-modal-panel">
          <header class="arch-modal-header">
            <div>
              <div class="arch-modal-layer-code" id="modal-layer-code"></div>
              <h3 class="arch-modal-title" id="modal-title"></h3>
            </div>
            <button class="arch-modal-close" aria-label="关闭">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2"><line x1="4" y1="4" x2="16" y2="16"/><line x1="16" y1="4" x2="4" y2="16"/></svg>
            </button>
          </header>
          <div class="arch-modal-body" id="modal-body"></div>
        </div>
      </div>
    </div>

    <!-- Hidden data for client-side modal rendering -->
    {layers.map((layer) =>
      layer.sections.map((section) =>
        section.items?.filter((item) => item.detail).map((item) => (
          <template data-modal-tpl={item.id} data-modal-layer={layer.code} data-modal-color={layer.color}>
            <div class="arch-modal-section">
              <h4>💡 {lang === "zh" ? "是什么" : "What"}</h4>
              <p set:html={item.detail!.what} />
            </div>
            <div class="arch-modal-section">
              <h4>🎯 {lang === "zh" ? "为什么重要" : "Why"}</h4>
              <p set:html={item.detail!.why} />
            </div>
            <div class="arch-modal-section">
              <h4>🔧 {lang === "zh" ? "实践指南" : "How"}</h4>
              <div set:html={item.detail!.how} />
            </div>
            {item.detail!.tools && (
              <div class="arch-modal-section">
                <h4>🛠 {lang === "zh" ? "推荐工具" : "Tools"}</h4>
                <div class="arch-modal-tools" set:html={item.detail!.tools} />
              </div>
            )}
            {item.detail!.tips && (
              <div class="arch-modal-section">
                <h4>⚠️ {lang === "zh" ? "注意事项" : "Tips"}</h4>
                <p set:html={item.detail!.tips} />
              </div>
            )}
          </template>
        ))
      )
    )}
  </main>
  <Footer lang={lang} />
</Layout>

<style>
  /* ═══════════════════════════════════════
     BASE & VARIABLES
     ═══════════════════════════════════════ */
  .arch-page {
    --arch-mono: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, monospace;
    min-height: 100vh;
  }

  .hidden { display: none !important; }

  /* ═══════════════════════════════════════
     HERO
     ═══════════════════════════════════════ */
  .arch-hero {
    position: relative;
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    overflow: hidden;
  }
  .arch-hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 50%, var(--hero-orb-a) 0%, transparent 50%),
      radial-gradient(circle at 80% 50%, var(--hero-orb-b) 0%, transparent 50%);
    opacity: 0.6;
    pointer-events: none;
  }
  .arch-hero-content {
    position: relative;
    max-width: 720px;
    margin: 0 auto;
  }
  .arch-hero-badge {
    font-family: var(--arch-mono);
    font-size: 0.65rem;
    letter-spacing: 0.15em;
    color: var(--accent);
    margin-bottom: 1rem;
  }
  .arch-hero-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--foreground);
    line-height: 1.2;
    margin-bottom: 1rem;
  }
  .arch-hero-desc {
    font-size: 0.95rem;
    color: var(--foreground-soft);
    line-height: 1.7;
    max-width: 560px;
    margin: 0 auto 1.5rem;
  }
  .arch-hero-stats {
    font-family: var(--arch-mono);
    font-size: 0.75rem;
    color: var(--foreground-soft);
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .arch-hero-stats strong { color: var(--accent); }
  .arch-hero-dot { opacity: 0.4; }

  /* ═══════════════════════════════════════
     VIEW CONTROLS
     ═══════════════════════════════════════ */
  .arch-controls {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    padding: 0 1.5rem 2rem;
  }
  .arch-view-btn {
    font-family: var(--arch-mono);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
    padding: 0.5rem 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    color: var(--foreground-soft);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.2s;
  }
  .arch-view-btn:hover { border-color: var(--accent); color: var(--accent); }
  .arch-view-btn.active {
    background: var(--accent);
    color: var(--background);
    border-color: var(--accent);
  }
  .arch-view-btn svg { width: 14px; height: 14px; }

  /* ═══════════════════════════════════════
     OVERVIEW LAYER
     ═══════════════════════════════════════ */
  .arch-overview {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .arch-overview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1rem;
  }
  .arch-layer-card {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    text-align: left;
    cursor: pointer;
    transition: all 0.2s;
    border-top: 3px solid var(--lc);
    overflow: hidden;
  }
  .arch-layer-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top right, color-mix(in srgb, var(--lc) 6%, transparent), transparent 70%);
    pointer-events: none;
  }
  .arch-layer-card:hover {
    border-color: color-mix(in srgb, var(--lc) 40%, var(--border));
    transform: translateY(-2px);
    box-shadow: 0 8px 24px var(--shadow-elevated);
  }
  .arch-lc-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    position: relative;
  }
  .arch-lc-icon { font-size: 1.25rem; }
  .arch-lc-code {
    font-family: var(--arch-mono);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    color: var(--lc);
  }
  .arch-lc-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: 0.35rem;
    position: relative;
  }
  .arch-lc-tagline {
    font-size: 0.8rem;
    color: var(--foreground-soft);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    position: relative;
  }
  .arch-lc-meta {
    font-family: var(--arch-mono);
    font-size: 0.65rem;
    color: var(--foreground-soft);
    display: flex;
    gap: 0.35rem;
    opacity: 0.7;
    position: relative;
  }
  .arch-lc-arrow {
    position: absolute;
    bottom: 1rem;
    right: 1.25rem;
    font-size: 1rem;
    color: var(--lc);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s;
  }
  .arch-layer-card:hover .arch-lc-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  /* AI Tag */
  .arch-ai-tag {
    font-family: var(--arch-mono);
    font-size: 0.55rem;
    letter-spacing: 0.06em;
    padding: 0.1rem 0.4rem;
    border-radius: 4px;
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    color: white;
    vertical-align: middle;
  }
  .arch-ai-tag.sm { font-size: 0.5rem; padding: 0.05rem 0.3rem; }

  /* ═══════════════════════════════════════
     DETAIL LAYER
     ═══════════════════════════════════════ */
  .arch-detail {
    display: flex;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
    gap: 2rem;
  }

  /* Sidebar */
  .arch-sidebar {
    width: 220px;
    flex-shrink: 0;
    position: sticky;
    top: 5rem;
    max-height: calc(100vh - 6rem);
    overflow-y: auto;
    padding-bottom: 2rem;
  }
  .arch-back-btn {
    font-family: var(--arch-mono);
    font-size: 0.7rem;
    color: var(--foreground-soft);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.4rem 0;
    margin-bottom: 1rem;
    letter-spacing: 0.04em;
    transition: color 0.15s;
  }
  .arch-back-btn:hover { color: var(--accent); }
  .arch-sidebar-list { display: flex; flex-direction: column; gap: 0.25rem; }
  .arch-sidebar-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    cursor: pointer;
    text-align: left;
    transition: all 0.15s;
    font-size: 0.75rem;
  }
  .arch-sidebar-item:hover { background: var(--surface); }
  .arch-sidebar-item.active {
    background: color-mix(in srgb, var(--lc) 10%, var(--surface));
    border-color: color-mix(in srgb, var(--lc) 25%, transparent);
  }
  .arch-si-icon { font-size: 0.9rem; flex-shrink: 0; }
  .arch-si-code {
    font-family: var(--arch-mono);
    font-size: 0.6rem;
    color: var(--lc);
    flex-shrink: 0;
  }
  .arch-si-name {
    color: var(--foreground);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Detail Content */
  .arch-detail-content { flex: 1; min-width: 0; }
  .arch-layer-detail {
    scroll-margin-top: 5rem;
    margin-bottom: 3rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    border-top: 3px solid var(--lc);
    overflow: hidden;
  }

  .arch-ld-header {
    display: flex;
    gap: 1rem;
    padding: 1.5rem 1.75rem;
    align-items: flex-start;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--lc) 4%, transparent);
  }
  .arch-ld-icon {
    font-size: 1.75rem;
    flex-shrink: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--lc) 12%, transparent);
  }
  .arch-ld-code {
    font-family: var(--arch-mono);
    font-size: 0.65rem;
    color: var(--lc);
    letter-spacing: 0.1em;
    margin-bottom: 0.15rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .arch-ld-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: 0.4rem;
  }
  .arch-ld-overview {
    font-size: 0.82rem;
    color: var(--foreground-soft);
    line-height: 1.6;
  }

  /* Sections */
  .arch-section { padding: 1.25rem 1.75rem; }
  .arch-section + .arch-section { border-top: 1px solid var(--border); }
  .arch-section-title {
    font-family: var(--arch-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--foreground-soft);
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .arch-section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Items Grid */
  .arch-items-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.5rem;
  }
  .arch-item {
    background: color-mix(in srgb, var(--lc) 3%, var(--background));
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    text-align: left;
    cursor: default;
    transition: all 0.15s;
  }
  .arch-item[data-has-detail="true"] {
    cursor: pointer;
  }
  .arch-item[data-has-detail="true"]:hover {
    border-color: var(--lc);
    background: color-mix(in srgb, var(--lc) 6%, var(--background));
  }
  .arch-item-head {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.3rem;
  }
  .arch-item-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--lc);
    flex-shrink: 0;
  }
  .arch-item-name {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--foreground);
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex: 1;
  }
  .arch-item-expand {
    font-size: 0.7rem;
    color: var(--lc);
    opacity: 0;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }
  .arch-item[data-has-detail="true"]:hover .arch-item-expand { opacity: 1; }
  .arch-item-brief {
    font-size: 0.72rem;
    color: var(--foreground-soft);
    line-height: 1.55;
  }

  /* Table */
  .arch-table-wrap {
    overflow-x: auto;
    border-radius: 8px;
    border: 1px solid var(--border);
  }
  .arch-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.75rem;
  }
  .arch-table th {
    font-family: var(--arch-mono);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    color: var(--foreground-soft);
    text-align: left;
    padding: 0.5rem 0.75rem;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--lc) 4%, var(--background));
    white-space: nowrap;
  }
  .arch-table td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--border);
    color: var(--foreground-soft);
    vertical-align: top;
  }
  .arch-table tr:last-child td { border-bottom: none; }
  .arch-table tr:hover td { background: color-mix(in srgb, var(--lc) 3%, transparent); }
  .arch-td-primary {
    font-weight: 500;
    color: var(--foreground);
    font-family: var(--arch-mono);
    font-size: 0.7rem;
    white-space: nowrap;
  }

  /* Callout */
  .arch-callout {
    border-left: 3px solid var(--lc);
    padding: 0.65rem 1rem;
    background: color-mix(in srgb, var(--lc) 5%, var(--background));
    border-radius: 0 8px 8px 0;
    font-size: 0.75rem;
    color: var(--foreground-soft);
    line-height: 1.6;
    margin-top: 0.75rem;
  }

  /* ═══════════════════════════════════════
     MODAL
     ═══════════════════════════════════════ */
  .arch-modal {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .arch-modal.hidden { display: none !important; }
  .arch-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
  }
  .arch-modal-container {
    position: relative;
    max-width: 680px;
    width: calc(100% - 2rem);
    max-height: calc(100vh - 4rem);
    overflow-y: auto;
  }
  .arch-modal-panel {
    background: var(--surface-strong, var(--surface));
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: 0 24px 64px var(--shadow-elevated);
    overflow: hidden;
  }
  .arch-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--modal-color, var(--accent)) 5%, transparent);
  }
  .arch-modal-layer-code {
    font-family: var(--arch-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: var(--modal-color, var(--accent));
    margin-bottom: 0.15rem;
  }
  .arch-modal-title {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--foreground);
  }
  .arch-modal-close {
    background: none;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.35rem;
    cursor: pointer;
    color: var(--foreground-soft);
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .arch-modal-close:hover {
    background: var(--muted);
    color: var(--foreground);
  }
  .arch-modal-body { padding: 1.5rem; }

  .arch-modal-section { margin-bottom: 1.25rem; }
  .arch-modal-section:last-child { margin-bottom: 0; }
  .arch-modal-section h4 {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--foreground);
    margin-bottom: 0.4rem;
  }
  .arch-modal-section p,
  .arch-modal-section div {
    font-size: 0.8rem;
    color: var(--foreground-soft);
    line-height: 1.7;
  }
  .arch-modal-section :global(code) {
    font-family: var(--arch-mono);
    font-size: 0.72rem;
    padding: 0.1rem 0.35rem;
    border-radius: 4px;
    background: var(--muted);
    color: var(--accent);
  }
  .arch-modal-section :global(br) { display: block; margin-bottom: 0.3rem; }
  .arch-modal-tools {
    font-family: var(--arch-mono);
    font-size: 0.72rem;
    color: var(--foreground-soft);
    line-height: 1.8;
  }

  /* ═══════════════════════════════════════
     RESPONSIVE
     ═══════════════════════════════════════ */
  @media (max-width: 768px) {
    .arch-hero { padding: 2.5rem 1rem 2rem; }
    .arch-overview { padding: 0 1rem 3rem; }
    .arch-overview-grid { grid-template-columns: 1fr; }

    .arch-detail {
      flex-direction: column;
      padding: 0 1rem 3rem;
    }
    .arch-sidebar {
      position: static;
      width: 100%;
      max-height: none;
      overflow-x: auto;
      padding-bottom: 0;
      margin-bottom: 1rem;
    }
    .arch-sidebar-list {
      flex-direction: row;
      gap: 0.35rem;
      overflow-x: auto;
      padding-bottom: 0.5rem;
    }
    .arch-sidebar-item { white-space: nowrap; font-size: 0.7rem; }
    .arch-si-name { display: none; }

    .arch-items-grid { grid-template-columns: 1fr; }

    .arch-modal-container { max-height: calc(100vh - 2rem); width: calc(100% - 1rem); }
    .arch-modal-panel { border-radius: 12px; }

    .arch-ld-header { flex-direction: column; gap: 0.75rem; }
  }
</style>

<script>
function initArchPage() {
  const overviewEl = document.getElementById('arch-overview');
  const detailEl = document.getElementById('arch-detail');
  const modalEl = document.getElementById('arch-modal');
  if (!overviewEl || !detailEl || !modalEl) return;

  const viewBtns = document.querySelectorAll<HTMLButtonElement>('.arch-view-btn');
  const layerCards = document.querySelectorAll<HTMLButtonElement>('.arch-layer-card');
  const sidebarItems = document.querySelectorAll<HTMLButtonElement>('.arch-sidebar-item');
  const items = document.querySelectorAll<HTMLButtonElement>('.arch-item[data-has-detail="true"]');
  const backBtn = document.querySelector<HTMLButtonElement>('[data-action="back"]');
  const modalClose = modalEl.querySelector<HTMLButtonElement>('.arch-modal-close');
  const modalBackdrop = modalEl.querySelector<HTMLElement>('.arch-modal-backdrop');

  let currentView: 'overview' | 'detail' = 'overview';

  function switchView(view: 'overview' | 'detail') {
    currentView = view;
    viewBtns.forEach(b => b.classList.toggle('active', b.dataset.view === view));
    overviewEl!.classList.toggle('hidden', view !== 'overview');
    detailEl!.classList.toggle('hidden', view !== 'detail');
  }

  function scrollToLayer(index: number) {
    const el = document.getElementById(`layer-${index}`);
    if (!el) return;
    el.scrollIntoView({ behavior: 'smooth', block: 'start' });
    sidebarItems.forEach(s => s.classList.remove('active'));
    sidebarItems[index]?.classList.add('active');
  }

  function openModal(itemId: string) {
    const tpl = document.querySelector<HTMLTemplateElement>(`[data-modal-tpl="${itemId}"]`);
    if (!tpl) return;

    const layerCode = tpl.dataset.modalLayer || '';
    const color = tpl.dataset.modalColor || '';
    const item = document.querySelector(`[data-item-id="${itemId}"]`);
    const title = item?.querySelector('.arch-item-name')?.textContent?.trim() || '';

    const headerCode = document.getElementById('modal-layer-code');
    const headerTitle = document.getElementById('modal-title');
    const body = document.getElementById('modal-body');
    if (!headerCode || !headerTitle || !body) return;

    headerCode.textContent = layerCode;
    headerTitle.textContent = title;
    body.innerHTML = '';
    body.appendChild(tpl.content.cloneNode(true));
    modalEl!.style.setProperty('--modal-color', color);
    modalEl!.classList.remove('hidden');
    document.body.style.overflow = 'hidden';

    const closeBtn = modalEl!.querySelector('.arch-modal-close') as HTMLElement;
    closeBtn?.focus();
  }

  function closeModal() {
    modalEl!.classList.add('hidden');
    document.body.style.overflow = '';
  }

  viewBtns.forEach(btn => {
    btn.addEventListener('click', () => switchView(btn.dataset.view as 'overview' | 'detail'));
  });

  layerCards.forEach(card => {
    card.addEventListener('click', () => {
      const index = parseInt(card.dataset.layerIndex || '0', 10);
      switchView('detail');
      setTimeout(() => scrollToLayer(index), 100);
    });
  });

  sidebarItems.forEach(item => {
    item.addEventListener('click', () => {
      const index = parseInt(item.dataset.navIndex || '0', 10);
      scrollToLayer(index);
    });
  });

  backBtn?.addEventListener('click', () => switchView('overview'));

  items.forEach(item => {
    item.addEventListener('click', () => {
      const id = item.dataset.itemId;
      if (id) openModal(id);
    });
  });

  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modalEl!.classList.contains('hidden')) {
      closeModal();
    }
  });

  // Intersection observer for sidebar highlighting
  const layerDetails = document.querySelectorAll('.arch-layer-detail');
  const observer = new IntersectionObserver((entries) => {
    if (currentView !== 'detail') return;
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const idx = (entry.target as HTMLElement).dataset.layerIdx;
        sidebarItems.forEach(s => s.classList.remove('active'));
        if (idx !== undefined) sidebarItems[parseInt(idx, 10)]?.classList.add('active');
      }
    });
  }, { rootMargin: '-15% 0px -75% 0px' });

  layerDetails.forEach(el => observer.observe(el));
}

initArchPage();
document.addEventListener('astro:page-load', initArchPage);
</script>
