---
import { randomUUID } from "node:crypto";

/**
 * Mermaid diagram component - 统一字体颜色版
 */
interface Props {
  code: string;
}

const { code } = Astro.props;
const uniqueId = `mermaid-${randomUUID()}`;
---

<div class="mermaid-wrapper my-6" data-mermaid-id={uniqueId}>
  <div class="mermaid-output overflow-x-auto" id={`${uniqueId}-output`}></div>
  <script
    type="application/json"
    class="mermaid-code"
    set:html={JSON.stringify(code)}
  />
</div>

<script>
  import mermaid from "mermaid";

  const isDark =
    document.documentElement.classList.contains("dark") ||
    document.documentElement.dataset.theme === "dark" ||
    (window.matchMedia &&
      window.matchMedia("(prefers-color-scheme: dark)").matches);

  // 统一使用相同的文字颜色，确保一致性
  const darkConfig = {
    theme: "base",
    themeVariables: {
      // 通用设置
      fontSize: "14px",
      fontFamily: '"Inter", "Segoe UI", system-ui, sans-serif',

      // 流程图 - 节点样式（关键！）
      primaryColor: "#1e293b",
      primaryTextColor: "#f8fafc", // 节点文字
      primaryBorderColor: "#6366f1",
      lineColor: "#94a3b8",
      background: "transparent",

      // 流程图 - 额外变量
      nodeBkg: "#1e293b",
      nodeBorder: "#6366f1",
      nodeTextColor: "#f8fafc", // 节点文字（确保）
      clusterBkg: "#1e293b",
      clusterBorder: "#6366f1",
      edgeLabelBackground: "#1e293b",

      // 时序图 - 参与者样式
      actorBorder: "#6366f1",
      actorBkg: "#1e293b",
      actorTextColor: "#f8fafc", // 参与者文字
      actorLineColor: "#94a3b8",

      // 时序图 - 消息样式
      signalColor: "#94a3b8",
      signalTextColor: "#f8fafc", // 消息文字
      sequenceNumberColor: "#f8fafc", // 序号

      // 标签背景
      noteBkg: "#1e293b",
      noteBorder: "#6366f1",
      noteTextColor: "#f8fafc",
    },
  };

  const lightConfig = {
    theme: "base",
    themeVariables: {
      fontSize: "14px",
      fontFamily: '"Inter", "Segoe UI", system-ui, sans-serif',

      // 流程图 - 节点样式
      primaryColor: "#eff6ff",
      primaryTextColor: "#1f2937", // 深色文字
      primaryBorderColor: "#3b82f6",
      lineColor: "#374151",
      background: "#ffffff",

      // 流程图 - 额外变量
      nodeBkg: "#eff6ff",
      nodeBorder: "#3b82f6",
      nodeTextColor: "#1f2937", // 深色文字
      clusterBkg: "#eff6ff",
      clusterBorder: "#3b82f6",
      edgeLabelBackground: "#ffffff",

      // 时序图 - 参与者样式
      actorBorder: "#3b82f6",
      actorBkg: "#f0f9ff",
      actorTextColor: "#1f2937", // 深色文字
      actorLineColor: "#374151",

      // 时序图 - 消息样式
      signalColor: "#374151",
      signalTextColor: "#1f2937", // 深色文字
      sequenceNumberColor: "#1f2937",

      // 标签
      noteBkg: "#f0f9ff",
      noteBorder: "#3b82f6",
      noteTextColor: "#1f2937",
    },
  };

  mermaid.initialize({
    startOnLoad: false,
    securityLevel: "loose",
    theme: "base" as const,
    themeVariables: (isDark ? darkConfig : lightConfig).themeVariables,
  });

  async function renderAllDiagrams() {
    const wrappers = document.querySelectorAll(".mermaid-wrapper");

    for (const wrapper of wrappers) {
      const id = wrapper.getAttribute("data-mermaid-id");
      const codeScript = wrapper.querySelector("script.mermaid-code");
      const output = document.getElementById(`${id}-output`);

      if (output && codeScript) {
        const code = JSON.parse(codeScript.textContent || '""');

        if (code && !output.innerHTML.trim()) {
          try {
            const { svg } = await mermaid.render(`${id}-svg`, code);
            output.innerHTML = svg;
          } catch (error) {
            console.error("Mermaid render error:", error);
            output.innerHTML = `<p class="mermaid-error">图表渲染错误: ${error instanceof Error ? error.message : '未知错误'}</p>`;
          }
        }
      }
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", renderAllDiagrams);
  } else {
    renderAllDiagrams();
  }

  document.addEventListener('astro:page-load', renderAllDiagrams);
</script>
<style>
  .mermaid-wrapper {
    display: flex;
    justify-content: center;
    padding: 1rem;
    border-radius: 0.5rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    width: 100%;
  }

  .mermaid-output {
    width: 100%;
    overflow-x: auto;
    display: flex;
    justify-content: center;
  }

  .mermaid-output :global(svg) {
    max-width: 100%;
    height: auto;
  }

  .mermaid-output :global(text) {
    font-size: 14px !important;
  }

  .mermaid-error {
    color: #ef4444;
    text-align: center;
    padding: 1rem;
  }

  /* 暗色模式 */
  :global(html[data-theme="dark"]) .mermaid-wrapper,
  :global(html.dark) .mermaid-wrapper {
    background: rgba(30, 41, 59, 0.5);
    border: 1px solid rgba(100, 116, 139, 0.3);
  }

  :global(html[data-theme="dark"]) .mermaid-error,
  :global(html.dark) .mermaid-error {
    color: #f87171;
  }
</style>
