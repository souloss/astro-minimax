{
  "name": "astro-minimax-blog",
  "version": "0.7.5",
  "private": true,
  "type": "module",
  "description": "A modern, minimalist blog built with Astro, featuring AI-powered search, multi-channel notifications, and rich visualizations.",
  "author": "Souloss",
  "license": "MIT",
  "keywords": [
    "astro",
    "blog",
    "personal-website",
    "tailwindcss",
    "cloudflare-pages",
    "ai",
    "rag",
    "minimalist"
  ],
  "homepage": "https://github.com/souloss/astro-minimax#readme",
  "bugs": {
    "url": "https://github.com/souloss/astro-minimax/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/souloss/astro-minimax",
    "directory": "apps/blog"
  },
  "scripts": {
    "dev": "concurrently -n \"astro,ai\" -c \"blue,green\" \"astro dev\" \"pnpm exec astro-ai-dev\"",
    "dev:astro": "astro dev",
    "dev:ai": "pnpm exec astro-ai-dev",
    "build": "astro check && astro build && pagefind --site dist",
    "preview": "wrangler pages dev dist",
    "preview:astro": "astro preview",
    "sync": "astro sync",
    "astro": "astro",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "astro check",
    "clean": "rm -rf dist .astro node_modules/.cache",
    "cli": "astro-minimax",
    "ai:process": "astro-minimax ai process",
    "ai:seo": "astro-minimax ai seo",
    "ai:summary": "astro-minimax ai summary",
    "ai:eval": "astro-minimax ai eval",
    "profile:build": "astro-minimax profile build",
    "profile:context": "astro-minimax profile context",
    "profile:voice": "astro-minimax profile voice",
    "profile:report": "astro-minimax profile report",
    "post:new": "astro-minimax post new",
    "post:list": "astro-minimax post list",
    "post:stats": "astro-minimax post stats",
    "data:status": "astro-minimax data status",
    "data:clear": "astro-minimax data clear"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/react": "^3.0.118",
    "@astro-minimax/ai": "workspace:*",
    "@astro-minimax/core": "workspace:*",
    "@astro-minimax/notify": "workspace:*",
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/preact": "^5.0.0",
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@resvg/resvg-js": "^2.6.2",
    "@shikijs/rehype": "^4.0.2",
    "@tailwindcss/vite": "^4.2.1",
    "ai": "^6.0.116",
    "astro": "^6.0.0",
    "dayjs": "^1.11.19",
    "lodash.kebabcase": "^4.1.1",
    "markmap-lib": "^0.18.11",
    "mermaid": "^11.12.3",
    "preact": "^10.29.0",
    "qrcode": "^1.5.4",
    "rehype-katex": "^7.0.1",
    "remark-emoji": "^5.0.2",
    "remark-github-alerts": "^0.1.1",
    "remark-markmap": "^1.1.5",
    "remark-math": "^6.0.0",
    "satori": "^0.25.0",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astro-minimax/cli": "workspace:*",
    "@astrojs/check": "^0.9.7",
    "@cloudflare/workers-types": "^4.20260313.1",
    "@pagefind/default-ui": "^1.4.0",
    "@shikijs/transformers": "^4.0.2",
    "@types/lodash.kebabcase": "^4.1.9",
    "concurrently": "^9.1.2",
    "eslint": "^9.39.3",
    "eslint-plugin-astro": "^1.6.0",
    "globals": "^16.5.0",
    "pagefind": "^1.4.0",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1",
    "wrangler": "^4.73.0"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
